// Helix Settings Studio - Sumer OS Control Center
// تصميم زجاجي متطور للوحة التحكم والإعدادات المركزية لنظام سومر OS مع دعم كامل للغة العربية

component ToggleSwitch inherits Rectangle {
    in-out property <bool> checked: false;
    callback toggled(bool);

    width: 46px;
    height: 24px;
    border-radius: 12px;
    background: checked ? #10b981 : #1e293b;
    border-width: 1px;
    border-color: checked ? #34d399 : #334155;

    animate background { duration: 150ms; }

    Rectangle {
        x: checked ? 24px : 2px;
        y: 2px;
        width: 20px;
        height: 20px;
        border-radius: 10px;
        background: #ffffff;

        animate x { duration: 150ms; }
    }

    TouchArea {
        clicked => {
            checked = !checked;
            root.toggled(checked);
        }
    }
}

component CustomSlider inherits Rectangle {
    in-out property <float> value: 0.5; // 0.0 to 1.0
    in-out property <string> icon: "";
    callback changed(float);

    height: 32px;
    background: transparent;

    HorizontalLayout {
        spacing: 12px;
        alignment: center;

        // Slider track
        track := Rectangle {
            height: 8px;
            background: #1e293b;
            border-radius: 4px;
            horizontal-stretch: 1;
            y: (parent.height - self.height)/2;

            // Fill
            Rectangle {
                x: 0;
                y: 0;
                width: parent.width * value;
                height: parent.height;
                background: @linear-gradient(90deg, #6366f1 0%, #a855f7 100%);
                border-radius: 4px;
            }

            // Handle
            handle := Rectangle {
                x: (parent.width - 16px) * value;
                y: -4px;
                width: 16px;
                height: 16px;
                border-radius: 8px;
                background: #ffffff;
                border-width: 3px;
                border-color: #6366f1;
            }

            TouchArea {
                width: parent.width;
                height: 32px;
                y: -12px;
                clicked => {
                    value = self.pressed-x / parent.width;
                    root.changed(value);
                }
                moved => {
                    if (self.pressed) {
                        value = Math.max(0.0, Math.min(1.0, self.mouse-x / parent.width));
                        root.changed(value);
                    }
                }
            }
        }

        if icon != "" : Text {
            text: icon;
            font-size: 16px;
            color: #94a3b8;
            vertical-alignment: center;
        }

        Text {
            text: Math.round(value * 100) + "%";
            color: #f1f5f9;
            font-size: 13px;
            font-weight: 700;
            width: 42px;
            horizontal-alignment: right;
            vertical-alignment: center;
        }
    }
}

component CustomButton inherits Rectangle {
    in-out property <string> text;
    in-out property <string> icon;
    in-out property <color> base-bg: #6366f1;
    in-out property <color> hover-bg: #4f46e5;
    in-out property <color> text-color: #ffffff;
    callback clicked;

    border-radius: 8px;
    background: touch-area.has-hover ? hover-bg : base-bg;
    border-width: 1px;
    border-color: touch-area.has-hover ? hover-bg.brighter(15%) : base-bg.brighter(10%);

    animate background { duration: 120ms; }

    HorizontalLayout {
        padding-left: 14px;
        padding-right: 14px;
        padding-top: 10px;
        padding-bottom: 10px;
        spacing: 8px;
        alignment: center;

        if icon != "" : Text {
            text: icon;
            color: text-color;
            font-size: 14px;
            vertical-alignment: center;
        }

        Text {
            text: text;
            color: text-color;
            font-size: 13px;
            font-weight: 700;
            vertical-alignment: center;
        }
    }

    touch-area := TouchArea {
        clicked => { root.clicked(); }
    }
}

component NavItem inherits Rectangle {
    in-out property <string> text;
    in-out property <string> icon;
    in-out property <bool> active;
    callback clicked;

    border-radius: 8px;
    background: active ? rgba(99, 102, 241, 0.18) : (touch-area.has-hover ? rgba(255, 255, 255, 0.05) : transparent);
    border-width: 1px;
    border-color: active ? rgba(99, 102, 241, 0.3) : (touch-area.has-hover ? rgba(255, 255, 255, 0.1) : transparent);

    animate background { duration: 120ms; }
    animate border-color { duration: 120ms; }

    HorizontalLayout {
        padding-left: 16px;
        padding-right: 16px;
        padding-top: 12px;
        padding-bottom: 12px;
        spacing: 12px;
        alignment: end; // RTL layout alignment

        Text {
            text: text;
            color: active ? #ffffff : #cbd5e1;
            font-size: 14px;
            font-weight: active ? 700 : 500;
            vertical-alignment: center;
            horizontal-alignment: right;
        }

        Text {
            text: icon;
            color: active ? #818cf8 : #94a3b8;
            font-size: 16px;
            vertical-alignment: center;
        }
    }

    touch-area := TouchArea {
        clicked => { root.clicked(); }
    }
}

component DropdownSelector inherits Rectangle {
    in-out property <string> label;
    in-out property <[string]> options;
    in-out property <int> selected-index: 0;
    callback selection-changed(int);

    background: transparent;

    VerticalLayout {
        spacing: 6px;
        alignment: start;

        Text {
            text: label;
            color: #94a3b8;
            font-size: 12px;
            font-weight: 700;
            horizontal-alignment: right;
        }

        HorizontalLayout {
            spacing: 6px;
            alignment: end;

            for opt[idx] in options : Rectangle {
                border-radius: 6px;
                background: selected-index == idx ? rgba(99, 102, 241, 0.2) : rgba(15, 23, 42, 0.45);
                border-width: 1px;
                border-color: selected-index == idx ? #6366f1 : rgba(30, 41, 59, 0.6);

                animate background { duration: 120ms; }

                HorizontalLayout {
                    padding-left: 14px;
                    padding-right: 14px;
                    padding-top: 8px;
                    padding-bottom: 8px;
                    alignment: center;

                    Text {
                        text: opt;
                        color: selected-index == idx ? #ffffff : #cbd5e1;
                        font-size: 12px;
                        font-weight: 600;
                    }
                }

                TouchArea {
                    clicked => {
                        selected-index = idx;
                        root.selection-changed(idx);
                    }
                }
            }
        }
    }
}

component CustomInput inherits Rectangle {
    in-out property <string> label;
    in-out property <string> placeholder;
    in-out property <string> text;
    callback edited(string);

    background: rgba(15, 23, 42, 0.55);
    border-radius: 8px;
    border-width: 1px;
    border-color: input-focus.has-focus ? #6366f1 : rgba(30, 41, 59, 0.8);
    height: 58px;

    animate border-color { duration: 150ms; }

    VerticalLayout {
        padding-left: 12px;
        padding-right: 12px;
        padding-top: 6px;
        padding-bottom: 6px;
        spacing: 2px;

        Text {
            text: label;
            color: input-focus.has-focus ? #818cf8 : #64748b;
            font-size: 11px;
            font-weight: 700;
            horizontal-alignment: right; // RTL
        }

        input-focus := TextInput {
            text: root.text;
            color: #f1f5f9;
            font-size: 13px;
            single-line: true;
            horizontal-alignment: right; // RTL
            
            edited => {
                root.text = self.text;
                root.edited(self.text);
            }
        }
    }
}

export component AppWindow inherits Window {
    title: "إعدادات هيليكس — Helix Settings";
    width: 960px;
    height: 680px;
    background: #090d16;

    // Navigation and App Control States
    in-out property <int> active-tab: 0; // 0: System, 1: Network, 2: Audio, 3: Display, 4: Users, 5: Security, 6: Power, 7: About
    in-out property <string> toast-msg: "تم تحميل الإعدادات بنجاح.";
    in-out property <bool> toast-active: false;
    in-out property <string> toast-type: "success"; // success, info, warning

    // Tab 0: System settings properties
    in-out property <string> sys-hostname: "sumer-os-desktop";
    in-out property <int> sys-lang-idx: 0;
    in-out property <int> sys-timezone-idx: 0;
    in-out property <bool> sys-developer-mode: false;

    // Tab 1: Network settings properties
    in-out property <bool> net-wifi-enabled: true;
    in-out property <bool> net-airplane-mode: false;
    in-out property <string> net-ip-address: "192.168.1.104";
    in-out property <string> net-active-wifi: "Sumer_Fiber_5G";
    in-out property <int> selected-wifi-idx: 0;

    // Tab 2: Audio settings properties
    in-out property <float> audio-master-vol: 0.75;
    in-out property <float> audio-system-vol: 0.50;
    in-out property <int> audio-output-idx: 0;
    in-out property <bool> audio-muted: false;

    // Tab 3: Display settings properties
    in-out property <float> disp-brightness: 0.85;
    in-out property <int> disp-resolution-idx: 0;
    in-out property <bool> disp-dark-mode: true;
    in-out property <int> disp-timeout-idx: 1;

    // Tab 4: Users settings properties
    in-out property <string> user-new-name: "";
    in-out property <string> user-new-pass: "";
    in-out property <int> user-new-role-idx: 1;
    in-out property <int> users-count: 2;

    // Tab 5: Security settings properties
    in-out property <bool> sec-screen-lock: true;
    in-out property <bool> sec-firewall: true;
    in-out property <bool> sec-encryption: false;
    in-out property <string> sec-curr-pass: "";
    in-out property <string> sec-new-pass: "";

    // Tab 6: Power settings properties
    in-out property <int> pwr-battery-level: 88;
    in-out property <bool> pwr-saver-mode: false;
    in-out property <bool> pwr-is-charging: true;

    // Tab 7: About System properties
    in-out property <string> about-os-version: "Sumer OS v2.1 (Alpine Linux Edition)";
    in-out property <string> about-kernel: "Linux 6.6.14-lts x86_64";
    in-out property <string> about-cpu: "Intel Core i7-11800H @ 2.30GHz";
    in-out property <string> about-ram: "16 GB DDR4 Dual-Channel";
    in-out property <string> about-storage: "512 GB NVMe SSD (24% مستخدم)";

    // Callbacks to simulate backend feedback in UI
    function show-toast-notification(msg: string, typ: string) {
        toast-msg = msg;
        toast-type = typ;
        toast-active = true;
    }

    HorizontalLayout {
        padding: 20px;
        spacing: 20px;

        // LEFT COLUMN: View Panel (Width dynamic, fills left space)
        Rectangle {
            horizontal-stretch: 1;
            background: rgba(15, 23, 42, 0.4);
            border-radius: 16px;
            border-width: 1px;
            border-color: rgba(30, 41, 59, 0.6);

            VerticalLayout {
                padding: 24px;
                spacing: 20px;

                // View Header (RTL title of active setting category)
                HorizontalLayout {
                    alignment: space-between;

                    // Left Side: Status / Quick indicators (glassmorphic badges)
                    HorizontalLayout {
                        spacing: 8px;
                        alignment: start;

                        if active-tab == 1 : Rectangle { // Wifi status badge
                            border-radius: 6px;
                            background: net-wifi-enabled ? rgba(16, 185, 129, 0.15) : rgba(239, 68, 68, 0.15);
                            border-width: 1px;
                            border-color: net-wifi-enabled ? rgba(16, 185, 129, 0.3) : rgba(239, 68, 68, 0.3);

                            HorizontalLayout {
                                padding-left: 10px;
                                padding-right: 10px;
                                padding-top: 4px;
                                padding-bottom: 4px;
                                spacing: 6px;

                                Text {
                                    text: net-wifi-enabled ? "متصل بـ " + net-active-wifi : "الواي فاي مغلق";
                                    color: net-wifi-enabled ? #34d399 : #f87171;
                                    font-size: 11px;
                                    font-weight: 700;
                                }
                            }
                        }

                        if active-tab == 6 : Rectangle { // Battery status badge
                            border-radius: 6px;
                            background: pwr-is-charging ? rgba(16, 185, 129, 0.15) : rgba(245, 158, 11, 0.15);
                            border-width: 1px;
                            border-color: pwr-is-charging ? rgba(16, 185, 129, 0.3) : rgba(245, 158, 11, 0.3);

                            HorizontalLayout {
                                padding-left: 10px;
                                padding-right: 10px;
                                padding-top: 4px;
                                padding-bottom: 4px;
                                spacing: 6px;

                                Text {
                                    text: (pwr-is-charging ? "⚡ متصل بالشاحن " : "🔋 على البطارية ") + pwr-battery-level + "%";
                                    color: pwr-is-charging ? #34d399 : #fbbf24;
                                    font-size: 11px;
                                    font-weight: 700;
                                }
                            }
                        }
                    }

                    // Right Side: Title text
                    HorizontalLayout {
                        spacing: 12px;
                        alignment: end;

                        Text {
                            text: active-tab == 0 ? "إعدادات النظام العامّة" :
                                  active-tab == 1 ? "إعدادات الاتصال والشبكة" :
                                  active-tab == 2 ? "تخصيص وإعدادات الصوت" :
                                  active-tab == 3 ? "إعدادات الشاشة والمظهر" :
                                  active-tab == 4 ? "إدارة مستخدمي النظام" :
                                  active-tab == 5 ? "الأمان وخصوصية البيانات" :
                                  active-tab == 6 ? "خيارات الطاقة والبطارية" : "حول نظام سومر OS";
                            color: #ffffff;
                            font-size: 18px;
                            font-weight: 800;
                            vertical-alignment: center;
                        }

                        Text {
                            text: active-tab == 0 ? "🖥️" :
                                  active-tab == 1 ? "📶" :
                                  active-tab == 2 ? "🔊" :
                                  active-tab == 3 ? "☀️" :
                                  active-tab == 4 ? "👥" :
                                  active-tab == 5 ? "🔐" :
                                  active-tab == 6 ? "⚡" : "🏛️";
                            font-size: 20px;
                            vertical-alignment: center;
                        }
                    }
                }

                // Separator
                Rectangle {
                    height: 1px;
                    background: rgba(255, 255, 255, 0.08);
                }

                // TAB CONTENT AREA
                VerticalLayout {
                    vertical-stretch: 1;
                    spacing: 16px;

                    // TAB 0: SYSTEM VIEW
                    if active-tab == 0 : VerticalLayout {
                        spacing: 16px;

                        // hostname card
                        Rectangle {
                            background: rgba(15, 23, 42, 0.3);
                            border-radius: 12px;
                            border-width: 1px;
                            border-color: rgba(255, 255, 255, 0.05);
                            padding: 16px;

                            VerticalLayout {
                                spacing: 12px;
                                Text {
                                    text: "هوية الجهاز والشبكة المحلية";
                                    color: #e2e8f0;
                                    font-size: 14px;
                                    font-weight: 700;
                                    horizontal-alignment: right;
                                }

                                CustomInput {
                                    label: "اسم مضيف الجهاز (Hostname)";
                                    text: root.sys-hostname;
                                    edited(val) => { root.sys-hostname = val; }
                                }
                            }
                        }

                        // regional card
                        Rectangle {
                            background: rgba(15, 23, 42, 0.3);
                            border-radius: 12px;
                            border-width: 1px;
                            border-color: rgba(255, 255, 255, 0.05);
                            padding: 16px;

                            VerticalLayout {
                                spacing: 16px;
                                Text {
                                    text: "خيارات اللغة والمنطقة الزمنية";
                                    color: #e2e8f0;
                                    font-size: 14px;
                                    font-weight: 700;
                                    horizontal-alignment: right;
                                }

                                DropdownSelector {
                                    label: "لغة العرض الرئيسية للمستخدم";
                                    options: ["العربية (Arabic)", "الإنجليزية (English)"];
                                    selected-index: root.sys-lang-idx;
                                    selection-changed(idx) => { 
                                        root.sys-lang-idx = idx;
                                        root.show-toast-notification("تم تغيير لغة النظام الافتراضية.", "info");
                                    }
                                }

                                DropdownSelector {
                                    label: "المنطقة الزمنية ومزامنة التوقيت";
                                    options: ["توقيت بغداد (GMT+3)", "توقيت مكة المكرمة (GMT+3)", "توقيت القاهرة (GMT+2)"];
                                    selected-index: root.sys-timezone-idx;
                                    selection-changed(idx) => { 
                                        root.sys-timezone-idx = idx;
                                        root.show-toast-notification("تم تحديث المنطقة الزمنية للنظام.", "info");
                                    }
                                }
                            }
                        }

                        // dev mode toggle
                        Rectangle {
                            background: rgba(15, 23, 42, 0.3);
                            border-radius: 12px;
                            border-width: 1px;
                            border-color: rgba(255, 255, 255, 0.05);
                            padding: 16px;

                            HorizontalLayout {
                                alignment: space-between;

                                ToggleSwitch {
                                    checked: root.sys-developer-mode;
                                    toggled(state) => {
                                        root.sys-developer-mode = state;
                                        if (state) {
                                            root.show-toast-notification("تم تفعيل وضع المطورين وخيارات تصحيح الأخطاء.", "warning");
                                        } else {
                                            root.show-toast-notification("تم إيقاف وضع المطورين.", "info");
                                        }
                                    }
                                }

                                VerticalLayout {
                                    alignment: center;
                                    Text {
                                        text: "تفعيل نمط المطور والمحاكاة";
                                        color: #e2e8f0;
                                        font-size: 13px;
                                        font-weight: 700;
                                        horizontal-alignment: right;
                                    }
                                    Text {
                                        text: "يسمح بتشغيل السكربتات المتقدمة والوصول إلى لوحة المطور.";
                                        color: #64748b;
                                        font-size: 11px;
                                        horizontal-alignment: right;
                                    }
                                }
                            }
                        }
                    }

                    // TAB 1: NETWORK VIEW
                    if active-tab == 1 : VerticalLayout {
                        spacing: 16px;

                        // wifi enable card
                        Rectangle {
                            background: rgba(15, 23, 42, 0.3);
                            border-radius: 12px;
                            border-width: 1px;
                            border-color: rgba(255, 255, 255, 0.05);
                            padding: 16px;

                            HorizontalLayout {
                                alignment: space-between;

                                ToggleSwitch {
                                    checked: root.net-wifi-enabled;
                                    toggled(state) => {
                                        root.net-wifi-enabled = state;
                                        if (state) {
                                            root.show-toast-notification("تم تشغيل الواي فاي وجاري البحث...", "info");
                                        } else {
                                            root.show-toast-notification("تم إيقاف تشغيل الواي فاي.", "info");
                                        }
                                    }
                                }

                                VerticalLayout {
                                    alignment: center;
                                    Text {
                                        text: "الاتصال اللاسلكي Wi-Fi";
                                        color: #e2e8f0;
                                        font-size: 14px;
                                        font-weight: 700;
                                        horizontal-alignment: right;
                                    }
                                    Text {
                                        text: "البحث عن الشبكات اللاسلكية المتاحة والاتصال بها.";
                                        color: #64748b;
                                        font-size: 11px;
                                        horizontal-alignment: right;
                                    }
                                }
                            }
                        }

                        // wifi network list
                        if net-wifi-enabled : Rectangle {
                            background: rgba(15, 23, 42, 0.3);
                            border-radius: 12px;
                            border-width: 1px;
                            border-color: rgba(255, 255, 255, 0.05);
                            padding: 16px;
                            vertical-stretch: 1;

                            VerticalLayout {
                                spacing: 10px;
                                alignment: start;

                                Text {
                                    text: "الشبكات اللاسلكية المكتشفة";
                                    color: #cbd5e1;
                                    font-size: 13px;
                                    font-weight: 700;
                                    horizontal-alignment: right;
                                }

                                // Mock list items of wifi
                                for item[idx] in [
                                    { name: "Sumer_Fiber_5G", secure: true, signal: "📶 الممتازة (متصل)", active: true },
                                    { name: "Home_WiFi_Standard", secure: true, signal: "📶 جيدة جداً", active: false },
                                    { name: "Public_Free_Internet", secure: false, signal: "📶 ضعيفة", active: false }
                                ] : Rectangle {
                                    height: 48px;
                                    background: item.active ? rgba(99, 102, 241, 0.1) : rgba(0, 0, 0, 0.15);
                                    border-radius: 8px;
                                    border-width: 1px;
                                    border-color: item.active ? rgba(99, 102, 241, 0.3) : rgba(255, 255, 255, 0.04);

                                    HorizontalLayout {
                                        padding-left: 12px;
                                        padding-right: 12px;
                                        alignment: space-between;

                                        // Connect button / Status icon
                                        HorizontalLayout {
                                            alignment: start;
                                            spacing: 10px;

                                            if !item.active : CustomButton {
                                                text: "اتصال";
                                                icon: "🔑";
                                                base-bg: #475569;
                                                hover-bg: #6366f1;
                                                clicked => {
                                                    root.net-active-wifi = item.name;
                                                    root.show-toast-notification("تم الاتصال بـ " + item.name + " بنجاح.", "success");
                                                }
                                            }

                                            if item.active : Text {
                                                text: "نشط حالياً";
                                                color: #34d399;
                                                font-size: 12px;
                                                font-weight: 700;
                                                vertical-alignment: center;
                                            }
                                        }

                                        // Wifi details (RTL)
                                        HorizontalLayout {
                                            spacing: 12px;
                                            alignment: end;

                                            Text {
                                                text: item.signal;
                                                color: #94a3b8;
                                                font-size: 11px;
                                                vertical-alignment: center;
                                            }

                                            Text {
                                                text: item.secure ? "🔒" : "🔓";
                                                font-size: 12px;
                                                vertical-alignment: center;
                                            }

                                            Text {
                                                text: item.name;
                                                color: item.active ? #ffffff : #cbd5e1;
                                                font-size: 13px;
                                                font-weight: 700;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        // airplane mode & details
                        Rectangle {
                            background: rgba(15, 23, 42, 0.3);
                            border-radius: 12px;
                            border-width: 1px;
                            border-color: rgba(255, 255, 255, 0.05);
                            padding: 16px;

                            HorizontalLayout {
                                alignment: space-between;

                                ToggleSwitch {
                                    checked: root.net-airplane-mode;
                                    toggled(state) => {
                                        root.net-airplane-mode = state;
                                        if (state) {
                                            root.net-wifi-enabled = false;
                                            root.show-toast-notification("تم تفعيل وضع الطيران. أُغلقت الاتصالات اللاسلكية.", "warning");
                                        } else {
                                            root.show-toast-notification("تم تعطيل وضع الطيران.", "info");
                                        }
                                    }
                                }

                                VerticalLayout {
                                    alignment: center;
                                    Text {
                                        text: "وضع الطيران (Airplane Mode)";
                                        color: #e2e8f0;
                                        font-size: 13px;
                                        font-weight: 700;
                                        horizontal-alignment: right;
                                    }
                                    Text {
                                        text: "إغلاق الواي فاي، البلوتوث وكافة الإشارات اللاسلكية.";
                                        color: #64748b;
                                        font-size: 11px;
                                        horizontal-alignment: right;
                                    }
                                }
                            }
                        }

                        // connection details (IP config)
                        Rectangle {
                            background: rgba(15, 23, 42, 0.3);
                            border-radius: 12px;
                            border-width: 1px;
                            border-color: rgba(255, 255, 255, 0.05);
                            padding: 16px;

                            VerticalLayout {
                                spacing: 10px;

                                Text {
                                    text: "تفاصيل عنوان IP للشبكة النشطة";
                                    color: #cbd5e1;
                                    font-size: 13px;
                                    font-weight: 700;
                                    horizontal-alignment: right;
                                }

                                HorizontalLayout {
                                    alignment: space-between;

                                    Text {
                                        text: root.net-ip-address;
                                        color: #38bdf8;
                                        font-size: 14px;
                                        font-weight: 700;
                                    }

                                    Text {
                                        text: "عنوان IP الحالي لجهازك :";
                                        color: #94a3b8;
                                        font-size: 13px;
                                        horizontal-alignment: right;
                                    }
                                }
                            }
                        }
                    }

                    // TAB 2: AUDIO VIEW
                    if active-tab == 2 : VerticalLayout {
                        spacing: 20px;

                        // master volume slider card
                        Rectangle {
                            background: rgba(15, 23, 42, 0.3);
                            border-radius: 12px;
                            border-width: 1px;
                            border-color: rgba(255, 255, 255, 0.05);
                            padding: 18px;

                            VerticalLayout {
                                spacing: 10px;

                                HorizontalLayout {
                                    alignment: space-between;
                                    Text {
                                        text: "🔊 مستوى الصوت الرئيسي";
                                        color: #e2e8f0;
                                        font-size: 14px;
                                        font-weight: 700;
                                    }
                                    Text {
                                        text: "مستوى شدة الصوت لكافة مكبرات الصوت الموصولة.";
                                        color: #64748b;
                                        font-size: 11px;
                                        vertical-alignment: center;
                                    }
                                }

                                CustomSlider {
                                    value: root.audio-master-vol;
                                    icon: "🔊";
                                    changed(val) => {
                                        root.audio-master-vol = val;
                                        if (val == 0.0) {
                                            root.audio-muted = true;
                                        } else {
                                            root.audio-muted = false;
                                        }
                                    }
                                }
                            }
                        }

                        // system sound slider card
                        Rectangle {
                            background: rgba(15, 23, 42, 0.3);
                            border-radius: 12px;
                            border-width: 1px;
                            border-color: rgba(255, 255, 255, 0.05);
                            padding: 18px;

                            VerticalLayout {
                                spacing: 10px;

                                Text {
                                    text: "🔔 أصوات التنبيهات والنظام";
                                    color: #e2e8f0;
                                    font-size: 14px;
                                    font-weight: 700;
                                    horizontal-alignment: right;
                                }

                                CustomSlider {
                                    value: root.audio-system-vol;
                                    icon: "🔔";
                                    changed(val) => {
                                        root.audio-system-vol = val;
                                    }
                                }
                            }
                        }

                        // mute and output device cards
                        Rectangle {
                            background: rgba(15, 23, 42, 0.3);
                            border-radius: 12px;
                            border-width: 1px;
                            border-color: rgba(255, 255, 255, 0.05);
                            padding: 18px;

                            VerticalLayout {
                                spacing: 16px;

                                HorizontalLayout {
                                    alignment: space-between;

                                    ToggleSwitch {
                                        checked: root.audio-muted;
                                        toggled(state) => {
                                            root.audio-muted = state;
                                            if (state) {
                                                root.audio-master-vol = 0.0;
                                                root.show-toast-notification("تم كتم كل الأصوات.", "warning");
                                            } else {
                                                root.audio-master-vol = 0.75;
                                                root.show-toast-notification("تم إلغاء كتم الصوت.", "info");
                                            }
                                        }
                                    }

                                    VerticalLayout {
                                        alignment: center;
                                        Text {
                                            text: "كتم الصوت بالكامل (Mute)";
                                            color: #e2e8f0;
                                            font-size: 13px;
                                            font-weight: 700;
                                            horizontal-alignment: right;
                                        }
                                        Text {
                                            text: "تعطيل كافة مخارج الصوت بالنظام.";
                                            color: #64748b;
                                            font-size: 11px;
                                            horizontal-alignment: right;
                                        }
                                    }
                                }

                                Rectangle {
                                    height: 1px;
                                    background: rgba(255, 255, 255, 0.06);
                                }

                                DropdownSelector {
                                    label: "جهاز إخراج الصوت الافتراضي (Output)";
                                    options: ["مكبر الصوت الداخلي (Built-in Speaker)", "سماعة الرأس USB (Headset USB Device)"];
                                    selected-index: root.audio-output-idx;
                                    selection-changed(idx) => {
                                        root.audio-output-idx = idx;
                                        root.show-toast-notification("تم تغيير منفذ مخرج الصوت بنجاح.", "success");
                                    }
                                }
                            }
                        }
                    }

                    // TAB 3: DISPLAY VIEW
                    if active-tab == 3 : VerticalLayout {
                        spacing: 20px;

                        // brightness card
                        Rectangle {
                            background: rgba(15, 23, 42, 0.3);
                            border-radius: 12px;
                            border-width: 1px;
                            border-color: rgba(255, 255, 255, 0.05);
                            padding: 18px;

                            VerticalLayout {
                                spacing: 10px;

                                Text {
                                    text: "☀️ مستوى سطوع الشاشة";
                                    color: #e2e8f0;
                                    font-size: 14px;
                                    font-weight: 700;
                                    horizontal-alignment: right;
                                }

                                CustomSlider {
                                    value: root.disp-brightness;
                                    icon: "☀️";
                                    changed(val) => {
                                        root.disp-brightness = val;
                                    }
                                }
                            }
                        }

                        // appearance card (theme)
                        Rectangle {
                            background: rgba(15, 23, 42, 0.3);
                            border-radius: 12px;
                            border-width: 1px;
                            border-color: rgba(255, 255, 255, 0.05);
                            padding: 18px;

                            HorizontalLayout {
                                alignment: space-between;

                                ToggleSwitch {
                                    checked: root.disp-dark-mode;
                                    toggled(state) => {
                                        root.disp-dark-mode = state;
                                        if (state) {
                                            root.show-toast-notification("تم تفعيل المظهر الداكن الكريستالي.", "info");
                                        } else {
                                            root.show-toast-notification("تم تفعيل المظهر الفاتح المشرق.", "info");
                                        }
                                    }
                                }

                                VerticalLayout {
                                    alignment: center;
                                    Text {
                                        text: "المظهر الداكن الكريستالي (Dark Glass Theme)";
                                        color: #e2e8f0;
                                        font-size: 13px;
                                        font-weight: 700;
                                        horizontal-alignment: right;
                                    }
                                    Text {
                                        text: "يمنحك واجهة زجاجية داكنة تحافظ على راحة العين واستهلاك الطاقة.";
                                        color: #64748b;
                                        font-size: 11px;
                                        horizontal-alignment: right;
                                    }
                                }
                            }
                        }

                        // resolution and timeout cards
                        Rectangle {
                            background: rgba(15, 23, 42, 0.3);
                            border-radius: 12px;
                            border-width: 1px;
                            border-color: rgba(255, 255, 255, 0.05);
                            padding: 18px;

                            VerticalLayout {
                                spacing: 16px;

                                DropdownSelector {
                                    label: "أبعاد ودقة الشاشة المعروضة (Resolution)";
                                    options: ["1920x1080 (16:9) FHD", "1366x768 (16:9) HD", "1280x800 (16:10) WXGA"];
                                    selected-index: root.disp-resolution-idx;
                                    selection-changed(idx) => {
                                        root.disp-resolution-idx = idx;
                                        root.show-toast-notification("تغيير الدقة قد يتطلب ثوانِ للمطابقة.", "info");
                                    }
                                }

                                Rectangle {
                                    height: 1px;
                                    background: rgba(255, 255, 255, 0.06);
                                }

                                DropdownSelector {
                                    label: "مدة خمول الشاشة قبل الإغلاق (Sleep Mode Timeout)";
                                    options: ["5 دقائق", "10 دقائق", "أبداً (شغالة دوماً)"];
                                    selected-index: root.disp-timeout-idx;
                                    selection-changed(idx) => {
                                        root.disp-timeout-idx = idx;
                                        root.show-toast-notification("تم تحديث مهلة سكون الشاشة.", "success");
                                    }
                                }
                            }
                        }
                    }

                    // TAB 4: USERS VIEW
                    if active-tab == 4 : VerticalLayout {
                        spacing: 16px;

                        // active users count card
                        Rectangle {
                            background: rgba(15, 23, 42, 0.3);
                            border-radius: 12px;
                            border-width: 1px;
                            border-color: rgba(255, 255, 255, 0.05);
                            padding: 16px;

                            HorizontalLayout {
                                alignment: space-between;

                                Text {
                                    text: root.users-count + " مستخدمين نشطين";
                                    color: #10b981;
                                    font-size: 14px;
                                    font-weight: 700;
                                    vertical-alignment: center;
                                }

                                VerticalLayout {
                                    alignment: center;
                                    Text {
                                        text: "المستخدمون الحاليون في النظام";
                                        color: #e2e8f0;
                                        font-size: 14px;
                                        font-weight: 700;
                                        horizontal-alignment: right;
                                    }
                                    Text {
                                        text: "الحسابات النشطة المسجلة في توزيعة سومر.";
                                        color: #64748b;
                                        font-size: 11px;
                                        horizontal-alignment: right;
                                    }
                                }
                            }
                        }

                        // list of active users
                        Rectangle {
                            background: rgba(15, 23, 42, 0.3);
                            border-radius: 12px;
                            border-width: 1px;
                            border-color: rgba(255, 255, 255, 0.05);
                            padding: 14px;

                            VerticalLayout {
                                spacing: 10px;

                                for usr[idx] in [
                                    { name: "مطور سومر (Sumer)", role: "مدير النظام (Admin)", avatar: "👨‍💻", deletable: false },
                                    { name: "حساب الضيف (Guest)", role: "مستخدم عادي", avatar: "👤", deletable: true }
                                ] : Rectangle {
                                    height: 48px;
                                    background: rgba(0, 0, 0, 0.2);
                                    border-radius: 8px;
                                    border-width: 1px;
                                    border-color: rgba(255, 255, 255, 0.04);

                                    HorizontalLayout {
                                        padding-left: 12px;
                                        padding-right: 12px;
                                        alignment: space-between;

                                        // Action delete
                                        HorizontalLayout {
                                            alignment: start;

                                            if usr.deletable : CustomButton {
                                                text: "حذف الحساب";
                                                icon: "🗑️";
                                                base-bg: rgba(239, 68, 68, 0.15);
                                                hover-bg: rgba(239, 68, 68, 0.35);
                                                text-color: #f87171;
                                                clicked => {
                                                    root.users-count = 1;
                                                    root.show-toast-notification("تم إزالة حساب " + usr.name + " من النظام.", "warning");
                                                }
                                            }

                                            if !usr.deletable : Text {
                                                text: "حساب محمي";
                                                color: #64748b;
                                                font-size: 11px;
                                                font-weight: 700;
                                                vertical-alignment: center;
                                            }
                                        }

                                        // details
                                        HorizontalLayout {
                                            spacing: 12px;
                                            alignment: end;

                                            VerticalLayout {
                                                alignment: center;
                                                Text {
                                                    text: usr.name;
                                                    color: #ffffff;
                                                    font-size: 13px;
                                                    font-weight: 700;
                                                    horizontal-alignment: right;
                                                }
                                                Text {
                                                    text: usr.role;
                                                    color: #94a3b8;
                                                    font-size: 10px;
                                                    horizontal-alignment: right;
                                                }
                                            }

                                            Rectangle {
                                                width: 32px;
                                                height: 32px;
                                                border-radius: 16px;
                                                background: rgba(255, 255, 255, 0.08);

                                                Text {
                                                    text: usr.avatar;
                                                    font-size: 14px;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        // add user form
                        Rectangle {
                            background: rgba(15, 23, 42, 0.3);
                            border-radius: 12px;
                            border-width: 1px;
                            border-color: rgba(255, 255, 255, 0.05);
                            padding: 16px;

                            VerticalLayout {
                                spacing: 12px;

                                Text {
                                    text: "إضافة حساب مستخدم جديد";
                                    color: #cbd5e1;
                                    font-size: 13px;
                                    font-weight: 700;
                                    horizontal-alignment: right;
                                }

                                HorizontalLayout {
                                    spacing: 10px;

                                    CustomInput {
                                        horizontal-stretch: 1;
                                        label: "اسم المستخدم الجديد";
                                        text: root.user-new-name;
                                        edited(val) => { root.user-new-name = val; }
                                    }

                                    CustomInput {
                                        horizontal-stretch: 1;
                                        label: "كلمة مرور الحساب";
                                        text: root.user-new-pass;
                                        edited(val) => { root.user-new-pass = val; }
                                    }
                                }

                                HorizontalLayout {
                                    alignment: space-between;

                                    CustomButton {
                                        text: "إنشاء المستخدم";
                                        icon: "➕";
                                        base-bg: #10b981;
                                        hover-bg: #059669;
                                        clicked => {
                                            if (root.user-new-name == "") {
                                                root.show-toast-notification("خطأ: يرجى كتابة اسم المستخدم الجديد!", "warning");
                                                return;
                                            }
                                            root.users-count = root.users-count + 1;
                                            root.show-toast-notification("تم إنشاء المستخدم " + root.user-new-name + " بنجاح.", "success");
                                            root.user-new-name = "";
                                            root.user-new-pass = "";
                                        }
                                    }

                                    DropdownSelector {
                                        label: "صلاحيات الوصول";
                                        options: ["مدير النظام", "مستخدم عادي"];
                                        selected-index: root.user-new-role-idx;
                                        selection-changed(idx) => { root.user-new-role-idx = idx; }
                                    }
                                }
                            }
                        }
                    }

                    // TAB 5: SECURITY VIEW
                    if active-tab == 5 : VerticalLayout {
                        spacing: 16px;

                        // toggle switches card
                        Rectangle {
                            background: rgba(15, 23, 42, 0.3);
                            border-radius: 12px;
                            border-width: 1px;
                            border-color: rgba(255, 255, 255, 0.05);
                            padding: 16px;

                            VerticalLayout {
                                spacing: 14px;

                                // screen lock toggle
                                HorizontalLayout {
                                    alignment: space-between;

                                    ToggleSwitch {
                                        checked: root.sec-screen-lock;
                                        toggled(state) => {
                                            root.sec-screen-lock = state;
                                            if (state) {
                                                root.show-toast-notification("تم تفعيل قفل الشاشة التلقائي بعد الخمول.", "info");
                                            } else {
                                                root.show-toast-notification("تم تعطيل قفل الشاشة. يرجى توخي الحذر.", "warning");
                                            }
                                        }
                                    }

                                    VerticalLayout {
                                        alignment: center;
                                        Text {
                                            text: "تفعيل قفل الشاشة والجلسة التلقائي";
                                            color: #e2e8f0;
                                            font-size: 13px;
                                            font-weight: 700;
                                            horizontal-alignment: right;
                                        }
                                        Text {
                                            text: "قفل الوصول للنظام فوراً عند سكون الشاشة لحماية خصوصيتك.";
                                            color: #64748b;
                                            font-size: 11px;
                                            horizontal-alignment: right;
                                        }
                                    }
                                }

                                Rectangle { height: 1px; background: rgba(255, 255, 255, 0.06); }

                                // firewall toggle
                                HorizontalLayout {
                                    alignment: space-between;

                                    ToggleSwitch {
                                        checked: root.sec-firewall;
                                        toggled(state) => {
                                            root.sec-firewall = state;
                                            if (state) {
                                                root.show-toast-notification("جدار الحماية (Firewall) نشط ويحمي المنافذ.", "success");
                                            } else {
                                                root.show-toast-notification("تحذير: تم إغلاق جدار الحماية بالكامل!", "warning");
                                            }
                                        }
                                    }

                                    VerticalLayout {
                                        alignment: center;
                                        Text {
                                            text: "جدار حماية النظام النشط (Enlil Firewall)";
                                            color: #e2e8f0;
                                            font-size: 13px;
                                            font-weight: 700;
                                            horizontal-alignment: right;
                                        }
                                        Text {
                                            text: "مراقبة وفلترة الاتصالات والزيارات غير المصرح بها.";
                                            color: #64748b;
                                            font-size: 11px;
                                            horizontal-alignment: right;
                                        }
                                    }
                                }

                                Rectangle { height: 1px; background: rgba(255, 255, 255, 0.06); }

                                // encryption toggle
                                HorizontalLayout {
                                    alignment: space-between;

                                    ToggleSwitch {
                                        checked: root.sec-encryption;
                                        toggled(state) => {
                                            root.sec-encryption = state;
                                            if (state) {
                                                root.show-toast-notification("جاري تهيئة تشفير المجلد الرئيسي للمستخدم...", "info");
                                            } else {
                                                root.show-toast-notification("تم إلغاء قفل تشفير البيانات.", "info");
                                            }
                                        }
                                    }

                                    VerticalLayout {
                                        alignment: center;
                                        Text {
                                            text: "تشفير ملفات القرص الرئيسي بـ AES-256";
                                            color: #e2e8f0;
                                            font-size: 13px;
                                            font-weight: 700;
                                            horizontal-alignment: right;
                                        }
                                        Text {
                                            text: "تأمين وحماية البيانات الشخصية والملفات في حال فقدان الجهاز.";
                                            color: #64748b;
                                            font-size: 11px;
                                            horizontal-alignment: right;
                                        }
                                    }
                                }
                            }
                        }

                        // password change card
                        Rectangle {
                            background: rgba(15, 23, 42, 0.3);
                            border-radius: 12px;
                            border-width: 1px;
                            border-color: rgba(255, 255, 255, 0.05);
                            padding: 16px;

                            VerticalLayout {
                                spacing: 12px;

                                Text {
                                    text: "تحديث كلمة مرور الحساب الإداري (root)";
                                    color: #cbd5e1;
                                    font-size: 13px;
                                    font-weight: 700;
                                    horizontal-alignment: right;
                                }

                                HorizontalLayout {
                                    spacing: 10px;

                                    CustomInput {
                                        horizontal-stretch: 1;
                                        label: "كلمة المرور الجديدة";
                                        text: root.sec-new-pass;
                                        edited(val) => { root.sec-new-pass = val; }
                                    }

                                    CustomInput {
                                        horizontal-stretch: 1;
                                        label: "كلمة المرور الحالية";
                                        text: root.sec-curr-pass;
                                        edited(val) => { root.sec-curr-pass = val; }
                                    }
                                }

                                HorizontalLayout {
                                    alignment: start;

                                    CustomButton {
                                        text: "تحديث كلمة المرور";
                                        icon: "🔐";
                                        base-bg: #6366f1;
                                        hover-bg: #4f46e5;
                                        clicked => {
                                            if (root.sec-curr-pass == "" || root.sec-new-pass == "") {
                                                root.show-toast-notification("خطأ: يجب ملء جميع حقول كلمات المرور!", "warning");
                                                return;
                                            }
                                            root.show-toast-notification("تم تحديث كلمة المرور للحساب الإداري.", "success");
                                            root.sec-curr-pass = "";
                                            root.sec-new-pass = "";
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // TAB 6: POWER VIEW
                    if active-tab == 6 : VerticalLayout {
                        spacing: 16px;

                        // battery percentage visualizer
                        Rectangle {
                            background: rgba(15, 23, 42, 0.3);
                            border-radius: 12px;
                            border-width: 1px;
                            border-color: rgba(255, 255, 255, 0.05);
                            padding: 20px;

                            VerticalLayout {
                                spacing: 14px;
                                alignment: center;

                                HorizontalLayout {
                                    alignment: space-between;

                                    Text {
                                        text: pwr-is-charging ? "⚡ جاري الشحن بنجاح" : "🔋 يتم تفريغ البطارية";
                                        color: pwr-is-charging ? #10b981 : #f59e0b;
                                        font-size: 14px;
                                        font-weight: 700;
                                        vertical-alignment: center;
                                    }

                                    Text {
                                        text: "مستوى شحن الطاقة الإجمالي";
                                        color: #e2e8f0;
                                        font-size: 14px;
                                        font-weight: 700;
                                        vertical-alignment: center;
                                    }
                                }

                                // Battery progress bar container
                                Rectangle {
                                    height: 24px;
                                    background: rgba(0, 0, 0, 0.3);
                                    border-radius: 12px;
                                    border-width: 1px;
                                    border-color: rgba(255, 255, 255, 0.08);

                                    // Battery level fill
                                    Rectangle {
                                        x: 0;
                                        y: 0;
                                        width: parent.width * (pwr-battery-level / 100.0);
                                        height: parent.height;
                                        background: pwr-battery-level > 20 ? @linear-gradient(90deg, #10b981 0%, #059669 100%) : @linear-gradient(90deg, #ef4444 0%, #dc2626 100%);
                                        border-radius: 12px;
                                    }

                                    // Percentage text centered
                                    Text {
                                        text: pwr-battery-level + "%";
                                        color: #ffffff;
                                        font-size: 12px;
                                        font-weight: 900;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }

                        // saver mode toggle
                        Rectangle {
                            background: rgba(15, 23, 42, 0.3);
                            border-radius: 12px;
                            border-width: 1px;
                            border-color: rgba(255, 255, 255, 0.05);
                            padding: 16px;

                            HorizontalLayout {
                                alignment: space-between;

                                ToggleSwitch {
                                    checked: root.pwr-saver-mode;
                                    toggled(state) => {
                                        root.pwr-saver-mode = state;
                                        if (state) {
                                            root.disp-brightness = 0.50; // Dim brightness automatically
                                            root.show-toast-notification("توفير الطاقة نشط. تم تقليل السطوع وتقنين العمليات الخلفية.", "info");
                                        } else {
                                            root.disp-brightness = 0.85;
                                            root.show-toast-notification("تم تعطيل وضع توفير الطاقة.", "info");
                                        }
                                    }
                                }

                                VerticalLayout {
                                    alignment: center;
                                    Text {
                                        text: "توفير طاقة البطارية (Battery Saver)";
                                        color: #e2e8f0;
                                        font-size: 13px;
                                        font-weight: 700;
                                        horizontal-alignment: right;
                                    }
                                    Text {
                                        text: "تقليل سطوع الشاشة والعمليات الثانوية لإطالة زمن الاستخدام.";
                                        color: #64748b;
                                        font-size: 11px;
                                        horizontal-alignment: right;
                                    }
                                }
                            }
                        }

                        // power quick actions (Shutdown, Restart, Sleep)
                        Rectangle {
                            background: rgba(15, 23, 42, 0.3);
                            border-radius: 12px;
                            border-width: 1px;
                            border-color: rgba(255, 255, 255, 0.05);
                            padding: 18px;

                            VerticalLayout {
                                spacing: 12px;

                                Text {
                                    text: "الإجراءات والعمليات السريعة للنظام";
                                    color: #cbd5e1;
                                    font-size: 13px;
                                    font-weight: 700;
                                    horizontal-alignment: right;
                                }

                                HorizontalLayout {
                                    spacing: 12px;

                                    CustomButton {
                                        horizontal-stretch: 1;
                                        text: "إيقاف التشغيل";
                                        icon: "🔴";
                                        base-bg: rgba(239, 68, 68, 0.2);
                                        hover-bg: rgba(239, 68, 68, 0.4);
                                        text-color: #f87171;
                                        clicked => {
                                            root.show-toast-notification("جاري إيقاف تشغيل نظام سومر OS...", "warning");
                                        }
                                    }

                                    CustomButton {
                                        horizontal-stretch: 1;
                                        text: "إعادة التشغيل";
                                        icon: "🔁";
                                        base-bg: rgba(245, 158, 11, 0.2);
                                        hover-bg: rgba(245, 158, 11, 0.4);
                                        text-color: #fbbf24;
                                        clicked => {
                                            root.show-toast-notification("جاري إعادة تشغيل النظام...", "warning");
                                        }
                                    }

                                    CustomButton {
                                        horizontal-stretch: 1;
                                        text: "وضعية السكون";
                                        icon: "🌙";
                                        base-bg: rgba(99, 102, 241, 0.2);
                                        hover-bg: rgba(99, 102, 241, 0.4);
                                        text-color: #a5b4fc;
                                        clicked => {
                                            root.show-toast-notification("وضع الجهاز في حالة سكون مؤقت.", "info");
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // TAB 7: ABOUT SYSTEM VIEW
                    if active-tab == 7 : VerticalLayout {
                        spacing: 16px;

                        // logo & main identity
                        Rectangle {
                            background: rgba(15, 23, 42, 0.3);
                            border-radius: 12px;
                            border-width: 1px;
                            border-color: rgba(255, 255, 255, 0.05);
                            padding: 16px;

                            HorizontalLayout {
                                spacing: 20px;
                                alignment: space-between;

                                VerticalLayout {
                                    alignment: center;
                                    spacing: 4px;

                                    Text {
                                        text: "نظام سومر — Sumer OS";
                                        color: #ffffff;
                                        font-size: 16px;
                                        font-weight: 800;
                                        horizontal-alignment: left;
                                    }
                                    Text {
                                        text: root.about-os-version;
                                        color: #38bdf8;
                                        font-size: 13px;
                                        font-weight: 700;
                                        horizontal-alignment: left;
                                    }
                                    Text {
                                        text: "نظام تشغيل عربي ذكي ومفتوح المصدر مبني على نواة Linux.";
                                        color: #94a3b8;
                                        font-size: 11px;
                                        horizontal-alignment: left;
                                    }
                                }

                                // logo badge
                                Rectangle {
                                    width: 64px;
                                    height: 64px;
                                    border-radius: 14px;
                                    background: @linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
                                    border-width: 1px;
                                    border-color: rgba(255, 255, 255, 0.2);

                                    Text {
                                        text: "🏛️";
                                        font-size: 32px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }

                        // technical specification list
                        Rectangle {
                            background: rgba(15, 23, 42, 0.3);
                            border-radius: 12px;
                            border-width: 1px;
                            border-color: rgba(255, 255, 255, 0.05);
                            padding: 14px;
                            vertical-stretch: 1;

                            VerticalLayout {
                                spacing: 10px;

                                for spec[idx] in [
                                    { name: "إصدار النواة (Kernel)", val: root.about-kernel, icon: "🐧" },
                                    { name: "المعالج (Processor)", val: root.about-cpu, icon: "💻" },
                                    { name: "الذاكرة العشوائية (RAM)", val: root.about-ram, icon: "📊" },
                                    { name: "مساحة التخزين (Storage)", val: root.about-storage, icon: "💾" }
                                ] : Rectangle {
                                    height: 42px;
                                    background: rgba(0, 0, 0, 0.15);
                                    border-radius: 6px;
                                    border-width: 1px;
                                    border-color: rgba(255, 255, 255, 0.03);

                                    HorizontalLayout {
                                        padding-left: 12px;
                                        padding-right: 12px;
                                        alignment: space-between;

                                        Text {
                                            text: spec.val;
                                            color: #ffffff;
                                            font-size: 12px;
                                            font-weight: 700;
                                            vertical-alignment: center;
                                        }

                                        HorizontalLayout {
                                            spacing: 10px;
                                            alignment: end;

                                            Text {
                                                text: spec.name;
                                                color: #94a3b8;
                                                font-size: 12px;
                                                font-weight: 600;
                                                vertical-alignment: center;
                                            }

                                            Text {
                                                text: spec.icon;
                                                font-size: 13px;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        // copyright & license
                        Rectangle {
                            background: rgba(15, 23, 42, 0.3);
                            border-radius: 12px;
                            border-width: 1px;
                            border-color: rgba(255, 255, 255, 0.05);
                            padding: 12px;

                            Text {
                                text: "مشروع نظام تشغيل سومر OS مفتوح المصدر بالكامل ومتاح للجميع. مرخص بموجب رخصة MIT.";
                                color: #64748b;
                                font-size: 11px;
                                font-weight: 600;
                                horizontal-alignment: center;
                            }
                        }
                    }
                }

                // Separator
                Rectangle {
                    height: 1px;
                    background: rgba(255, 255, 255, 0.08);
                }

                // BOTTOM STATUS BAR (Toast Notifications)
                HorizontalLayout {
                    height: 36px;
                    alignment: space-between;

                    // Left side: Reset UI button
                    CustomButton {
                        text: "إعادة تعيين الافتراضيات";
                        icon: "🔄";
                        base-bg: rgba(255, 255, 255, 0.05);
                        hover-bg: rgba(255, 255, 255, 0.1);
                        text-color: #cbd5e1;
                        clicked => {
                            root.sys-hostname = "sumer-os-desktop";
                            root.sys-lang-idx = 0;
                            root.sys-timezone-idx = 0;
                            root.sys-developer-mode = false;
                            root.net-wifi-enabled = true;
                            root.net-airplane-mode = false;
                            root.audio-master-vol = 0.75;
                            root.audio-muted = false;
                            root.disp-brightness = 0.85;
                            root.disp-dark-mode = true;
                            root.sec-screen-lock = true;
                            root.sec-firewall = true;
                            root.pwr-saver-mode = false;
                            root.show-toast-notification("تم استعادة كافة إعدادات لوحة التحكم الافتراضية.", "info");
                        }
                    }

                    // Right side: Active toast or status notifier
                    if toast-active : Rectangle {
                        background: toast-type == "success" ? rgba(16, 185, 129, 0.15) :
                                    (toast-type == "warning" ? rgba(239, 68, 68, 0.15) : rgba(56, 189, 248, 0.15));
                        border-radius: 6px;
                        border-width: 1px;
                        border-color: toast-type == "success" ? rgba(16, 185, 129, 0.3) :
                                      (toast-type == "warning" ? rgba(239, 68, 68, 0.3) : rgba(56, 189, 248, 0.3));

                        HorizontalLayout {
                            padding-left: 14px;
                            padding-right: 14px;
                            spacing: 8px;
                            alignment: center;

                            Text {
                                text: toast-msg;
                                color: toast-type == "success" ? #34d399 :
                                       (toast-type == "warning" ? #f87171 : #38bdf8);
                                font-size: 11px;
                                font-weight: 700;
                                vertical-alignment: center;
                            }

                            // Dismiss button
                            Rectangle {
                                width: 14px;
                                height: 14px;
                                border-radius: 7px;
                                background: rgba(255, 255, 255, 0.15);

                                Text {
                                    text: "×";
                                    color: #ffffff;
                                    font-size: 10px;
                                    font-weight: 900;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }

                                TouchArea {
                                    clicked => { root.toast-active = false; }
                                }
                            }
                        }
                    }

                    if !toast-active : Text {
                        text: "لوحة التحكم هيليكس جاهزة للعمل.";
                        color: #64748b;
                        font-size: 11px;
                        font-weight: 600;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // RIGHT COLUMN: Sidebar / Navigation Panel (Width 220px)
        Rectangle {
            width: 230px;
            background: rgba(15, 23, 42, 0.45);
            border-radius: 16px;
            border-width: 1px;
            border-color: rgba(30, 41, 59, 0.6);

            VerticalLayout {
                padding: 16px;
                spacing: 16px;

                // Application Title & Brand Header
                HorizontalLayout {
                    spacing: 10px;
                    alignment: end;

                    VerticalLayout {
                        alignment: center;
                        Text {
                            text: "لوحة التحكم";
                            color: #ffffff;
                            font-size: 15px;
                            font-weight: 800;
                            horizontal-alignment: right;
                        }
                        Text {
                            text: "إعدادات هيليكس / Helix";
                            color: #64748b;
                            font-size: 10px;
                            font-weight: 600;
                            horizontal-alignment: right;
                        }
                    }

                    Rectangle {
                        width: 36px;
                        height: 36px;
                        border-radius: 8px;
                        background: @linear-gradient(135deg, #6366f1 0%, #a855f7 100%);

                        Text {
                            text: "⚙️";
                            font-size: 16px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                // Separator
                Rectangle {
                    height: 1px;
                    background: rgba(255, 255, 255, 0.08);
                }

                // Navigation Items List (RTL Sidebar)
                VerticalLayout {
                    vertical-stretch: 1;
                    spacing: 6px;

                    NavItem {
                        text: "النظام / System";
                        icon: "🖥️";
                        active: root.active-tab == 0;
                        clicked => { root.active-tab = 0; root.toast-active = false; }
                    }

                    NavItem {
                        text: "الشبكة / Network";
                        icon: "📶";
                        active: root.active-tab == 1;
                        clicked => { root.active-tab = 1; root.toast-active = false; }
                    }

                    NavItem {
                        text: "الصوت / Audio";
                        icon: "🔊";
                        active: root.active-tab == 2;
                        clicked => { root.active-tab = 2; root.toast-active = false; }
                    }

                    NavItem {
                        text: "الشاشة / Display";
                        icon: "☀️";
                        active: root.active-tab == 3;
                        clicked => { root.active-tab = 3; root.toast-active = false; }
                    }

                    NavItem {
                        text: "المستخدمون / Users";
                        icon: "👥";
                        active: root.active-tab == 4;
                        clicked => { root.active-tab = 4; root.toast-active = false; }
                    }

                    NavItem {
                        text: "الأمان / Security";
                        icon: "🔐";
                        active: root.active-tab == 5;
                        clicked => { root.active-tab = 5; root.toast-active = false; }
                    }

                    NavItem {
                        text: "الطاقة / Power";
                        icon: "⚡";
                        active: root.active-tab == 6;
                        clicked => { root.active-tab = 6; root.toast-active = false; }
                    }

                    NavItem {
                        text: "حول النظام / About";
                        icon: "🏛️";
                        active: root.active-tab == 7;
                        clicked => { root.active-tab = 7; root.toast-active = false; }
                    }
                }

                // Separator
                Rectangle {
                    height: 1px;
                    background: rgba(255, 255, 255, 0.08);
                }

                // Footer logo or text
                Text {
                    text: "نظام تشغيل سومر © 2026";
                    color: #475569;
                    font-size: 9px;
                    font-weight: 700;
                    horizontal-alignment: center;
                }
            }
        }
    }
}
