import { TopBar } from "./components/top_bar.slint";
import { AppGrid, AppItem } from "./components/app_grid.slint";
import { VolumeBar } from "./components/volume_bar.slint";
import { BrightnessBar } from "./components/brightness_bar.slint";
import { SettingsPanel } from "./components/settings_panel.slint";
import { AppCard } from "./components/app_card.slint";
import { TvColors } from "./theme/colors.slint";
import { TvTypography } from "./theme/typography.slint";
import { TvSpacing } from "./theme/spacing.slint";

export component MainWindow inherits Window {
    preferred-width: 1024px;
    preferred-height: 600px;
    background: @linear-gradient(135deg, TvColors.background-gradient-start 0%, TvColors.background-gradient-end 100%);
    title: "Nahar TV - Sumer OS";
    default-font-size: 16px;
    
    // Properties synced with Rust controller
    in-out property <string> current-time: "12:00 PM";
    in-out property <bool> show-volume-bar: false;
    in-out property <int> system-volume: 80;
    in-out property <bool> show-settings: false;
    in-out property <bool> show-brightness-bar: false;
    in-out property <bool> wifi-enabled: true;
    in-out property <bool> airplane-mode: false;
    in-out property <bool> bluetooth-enabled: true;
    in-out property <bool> bluetooth-connecting: false;
    in-out property <string> bluetooth-connection-status: "";
    in-out property <int> system-brightness: 90;
    in-out property <string> perf-mode: "Supernova 🔴";
    in-out property <bool> dark-mode: true;
    in-out property <bool> camera-enabled: true;
    in-out property <bool> mic-enabled: true;
    in-out property <bool> location-enabled: true;
    in-out property <int> screensaver-timeout: 30;
    in-out property <int> screensaver-image-mode: -1;
    in-out property <string> screensaver-sub-page: "main";
    
    // Callbacks to Rust
    callback back-clicked();
    callback app-clicked(string);
    callback play-navigation-sound();
    callback bluetooth-device-clicked(string);
    callback trigger-volume-timer();
    callback trigger-brightness-timer();
    
    // Local navigation states
    in-out property <string> active-tab: "home";
    in-out property <int> focused-row: 1;
    in-out property <int> focused-col-0: 1; // TopBar (0=Back, 1=Home, 2=Store, 3=Files, 4=Console, 5=Settings)
    in-out property <int> focused-col-1: 0; // Core Apps (0..5)
    in-out property <int> focused-col-2: 0; // Installed Apps (0..9)
    in-out property <int> settings-focused-row: 0;
    in-out property <int> subpage-focused-row: 0;
    in-out property <string> settings-page: "main";
    
    // Dynamic App Data models declared locally
    in property <[AppItem]> core-apps: [
        { text: "متجر التطبيقات 🛍️", category-text: "", category-color: TvColors.accent, text-color: TvColors.text-primary, card-background: TvColors.store-bg, action-id: "Store" },
        { text: "الملفات 📂", category-text: "", category-color: TvColors.accent, text-color: TvColors.text-primary, card-background: TvColors.files-bg, action-id: "Files" },
        { text: "الطرفية 💻", category-text: "", category-color: TvColors.accent, text-color: TvColors.text-primary, card-background: TvColors.console-bg, action-id: "Console" },
        { text: "المتصفح 🌐", category-text: "", category-color: TvColors.accent, text-color: TvColors.text-primary, card-background: TvColors.browser-bg, action-id: "Browser" },
        { text: "الإعدادات ⚙️", category-text: "", category-color: TvColors.accent, text-color: TvColors.text-primary, card-background: TvColors.settings-bg, action-id: "Settings" },
        { text: "إيقاف التشغيل 🛑", category-text: "", category-color: TvColors.accent, text-color: TvColors.text-primary, card-background: TvColors.shutdown-bg, action-id: "Shutdown" }
    ];
    
    in property <[AppItem]> installed-apps: [
        { text: "مشغل الوسائط", category-text: "الوسائط 🎬", category-color: TvColors.accent, text-color: TvColors.text-primary, card-background: @linear-gradient(135deg, TvColors.media-player-grad-start 0%, TvColors.media-player-grad-end 100%), action-id: "MediaPlayer" },
        { text: "ألعاب كلاسيكية", category-text: "الألعاب 🎮", category-color: TvColors.retro-games-accent, text-color: TvColors.text-primary, card-background: @linear-gradient(135deg, TvColors.retro-games-grad-start 0%, TvColors.retro-games-grad-end 100%), action-id: "RetroGames" },
        { text: "محرر النصوص", category-text: "الإنتاجية 📝", category-color: TvColors.text-editor-accent, text-color: TvColors.text-primary, card-background: @linear-gradient(135deg, TvColors.text-editor-grad-start 0%, TvColors.text-editor-grad-end 100%), action-id: "TextEditor" },
        { text: "مراقب النظام", category-text: "النظام 📊", category-color: TvColors.sys-monitor-accent, text-color: TvColors.text-primary, card-background: @linear-gradient(135deg, TvColors.sys-monitor-grad-start 0%, TvColors.sys-monitor-grad-end 100%), action-id: "SysMonitor" },
        { text: "مشغل الموسيقى", category-text: "الصوتيات 🎵", category-color: TvColors.music-player-accent, text-color: TvColors.text-primary, card-background: @linear-gradient(135deg, TvColors.music-player-grad-start 0%, TvColors.music-player-grad-end 100%), action-id: "MusicPlayer" },
        { text: "مدير Docker", category-text: "المطور 🐳", category-color: TvColors.docker-accent, text-color: TvColors.text-primary, card-background: @linear-gradient(135deg, TvColors.docker-grad-start 0%, TvColors.docker-grad-end 100%), action-id: "Docker" },
        { text: "الآلة الحاسبة", category-text: "الأدوات 🧮", category-color: TvColors.calculator-accent, text-color: TvColors.text-primary, card-background: @linear-gradient(135deg, TvColors.calculator-grad-start 0%, TvColors.calculator-grad-end 100%), action-id: "Calculator" },
        { text: "محلل الشبكة", category-text: "الأمان 🛡️", category-color: TvColors.network-accent, text-color: TvColors.text-primary, card-background: @linear-gradient(135deg, TvColors.network-grad-start 0%, TvColors.network-grad-end 100%), action-id: "Network" },
        { text: "مسجل الشاشة", category-text: "الأدوات 📹", category-color: TvColors.recorder-accent, text-color: TvColors.text-primary, card-background: @linear-gradient(135deg, TvColors.recorder-grad-start 0%, TvColors.recorder-grad-end 100%), action-id: "Recorder" },
        { text: "مساعد Sumer AI", category-text: "الذكاء الاصطناعي 🤖", category-color: TvColors.ai-accent, text-color: TvColors.text-primary, card-background: @linear-gradient(135deg, TvColors.ai-grad-start 0%, TvColors.ai-grad-end 100%), action-id: "AIAssistant" }
    ];
    
    // Universal D-Pad remote control key capture
    fs := FocusScope {
        key-pressed(event) => {
            if (event.text == Key.LeftArrow || event.text == Key.RightArrow || 
                event.text == Key.UpArrow || event.text == Key.DownArrow || event.text == Key.Return) {
                root.play-navigation-sound();
            }
            
            // Volume / Brightness hotkey overrides (+ / -)
            if (event.text == "+") {
                root.system-volume = Math.min(100, root.system-volume + 5);
                root.show-volume-bar = true;
                root.trigger-volume-timer();
                return accept;
            }
            if (event.text == "-") {
                root.system-volume = Math.max(0, root.system-volume - 5);
                root.show-volume-bar = true;
                root.trigger-volume-timer();
                return accept;
            }
            
            // SETTINGS SIDEBAR ACTIVE
            if (root.show-settings) {
                if (event.text == Key.Escape) {
                    root.show-settings = false;
                    return accept;
                }
                
                if (root.settings-page == "main") {
                    if (event.text == Key.UpArrow) {
                        root.settings-focused-row = Math.max(0, root.settings-focused-row - 1);
                        return accept;
                    }
                    if (event.text == Key.DownArrow) {
                        root.settings-focused-row = Math.min(8, root.settings-focused-row + 1);
                        return accept;
                    }
                    if (event.text == Key.LeftArrow) {
                        root.show-settings = false;
                        return accept;
                    }
                    if (event.text == Key.Return) {
                        if (root.settings-focused-row == 0) { root.settings-page = "wifi"; root.subpage-focused-row = 0; }
                        else if (root.settings-focused-row == 1) { root.airplane-mode = !root.airplane-mode; if (root.airplane-mode) { root.wifi-enabled = false; } }
                        else if (root.settings-focused-row == 2) { root.settings-page = "bluetooth"; root.subpage-focused-row = 0; }
                        else if (root.settings-focused-row == 3) { root.show-volume-bar = true; root.trigger-volume-timer(); }
                        else if (root.settings-focused-row == 4) { root.show-brightness-bar = true; root.trigger-brightness-timer(); }
                        else if (root.settings-focused-row == 5) {
                            if (root.perf-mode == "Supernova 🔴") { root.perf-mode = "Eco 🟢"; }
                            else if (root.perf-mode == "Eco 🟢") { root.perf-mode = "Balanced 🟡"; }
                            else { root.perf-mode = "Supernova 🔴"; }
                        }
                        else if (root.settings-focused-row == 6) { root.settings-page = "hardware"; root.subpage-focused-row = 0; }
                        else if (root.settings-focused-row == 7) { root.settings-page = "screensaver"; root.screensaver-sub-page = "main"; root.subpage-focused-row = 0; }
                        else if (root.settings-focused-row == 8) { root.show-settings = false; }
                        return accept;
                    }
                }
                
                // SUBPAGES NAVIGATION
                if (root.settings-page == "wifi" || root.settings-page == "bluetooth" || root.settings-page == "hardware") {
                    if (event.text == Key.LeftArrow) { root.settings-page = "main"; return accept; }
                    
                    if (event.text == Key.UpArrow) {
                        root.subpage-focused-row = Math.max(-1, root.subpage-focused-row - 1);
                        return accept;
                    }
                    if (event.text == Key.DownArrow) {
                        root.subpage-focused-row = Math.min(
                            root.settings-page == "wifi" ? (root.wifi-enabled ? 3 : 0) :
                            root.settings-page == "bluetooth" ? (root.bluetooth-enabled ? 4 : 0) : 2,
                            root.subpage-focused-row + 1
                        );
                        return accept;
                    }
                    if (event.text == Key.Return) {
                        if (root.subpage-focused-row == -1) { root.settings-page = "main"; }
                        else if (root.settings-page == "wifi") {
                            if (root.subpage-focused-row == 0) { root.wifi-enabled = !root.wifi-enabled; }
                            else if (root.subpage-focused-row == 1) { root.wifi-network-clicked("Sumer Network 5G 📡"); }
                            else if (root.subpage-focused-row == 2) { root.wifi-network-clicked("Al-Rafidain Net 🌐"); }
                            else if (root.subpage-focused-row == 3) { root.wifi-network-clicked("Babylon Home 🏛️"); }
                        }
                        else if (root.settings-page == "bluetooth") {
                            if (root.subpage-focused-row == 0) { root.bluetooth-enabled = !root.bluetooth-enabled; }
                            else if (root.subpage-focused-row == 1) { root.bluetooth-device-clicked("Sumer Buds Pro 🎧"); }
                            else if (root.subpage-focused-row == 2) { root.bluetooth-device-clicked("Smart TV 📺"); }
                            else if (root.subpage-focused-row == 3) { root.bluetooth-device-clicked("Magic Keyboard ⌨️"); }
                            else if (root.subpage-focused-row == 4) { root.bluetooth-device-clicked("Watch Ultra ⌚"); }
                        }
                        else if (root.settings-page == "hardware") {
                            if (root.subpage-focused-row == 0) { root.camera-enabled = !root.camera-enabled; }
                            else if (root.subpage-focused-row == 1) { root.mic-enabled = !root.mic-enabled; }
                            else if (root.subpage-focused-row == 2) { root.location-enabled = !root.location-enabled; }
                        }
                        return accept;
                    }
                }
                
                if (root.settings-page == "screensaver") {
                    if (root.screensaver-sub-page == "main") {
                        if (event.text == Key.LeftArrow) { root.settings-page = "main"; return accept; }
                        if (event.text == Key.UpArrow) { root.subpage-focused-row = Math.max(-1, root.subpage-focused-row - 1); return accept; }
                        if (event.text == Key.DownArrow) { root.subpage-focused-row = Math.min(1, root.subpage-focused-row + 1); return accept; }
                        if (event.text == Key.Return) {
                            if (root.subpage-focused-row == -1) { root.settings-page = "main"; }
                            else if (root.subpage-focused-row == 0) { root.screensaver-sub-page = "timeout"; root.subpage-focused-row = 0; }
                            else if (root.subpage-focused-row == 1) { root.screensaver-sub-page = "wallpaper"; root.subpage-focused-row = 0; }
                            return accept;
                        }
                    }
                    else if (root.screensaver-sub-page == "timeout") {
                        if (event.text == Key.LeftArrow) { root.screensaver-sub-page = "main"; root.subpage-focused-row = 0; return accept; }
                        if (event.text == Key.UpArrow) { root.subpage-focused-row = Math.max(-1, root.subpage-focused-row - 1); return accept; }
                        if (event.text == Key.DownArrow) { root.subpage-focused-row = Math.min(5, root.subpage-focused-row + 1); return accept; }
                        if (event.text == Key.Return) {
                            if (root.subpage-focused-row == -1) { root.screensaver-sub-page = "main"; root.subpage-focused-row = 0; }
                            else {
                                if (root.subpage-focused-row == 0) { root.screensaver-timeout = 5; }
                                else if (root.subpage-focused-row == 1) { root.screensaver-timeout = 10; }
                                else if (root.subpage-focused-row == 2) { root.screensaver-timeout = 20; }
                                else if (root.subpage-focused-row == 3) { root.screensaver-timeout = 30; }
                                else if (root.subpage-focused-row == 4) { root.screensaver-timeout = 60; }
                                else if (root.subpage-focused-row == 5) { root.screensaver-timeout = -1; }
                                root.screensaver-sub-page = "main"; root.subpage-focused-row = 0;
                            }
                            return accept;
                        }
                    }
                }
                return accept;
            }
            
            // LAUNCHER MENU NAVIGATION
            if (event.text == Key.UpArrow) {
                root.focused-row = Math.max(0, root.focused-row - 1);
                return accept;
            }
            if (event.text == Key.DownArrow) {
                root.focused-row = Math.min(3, root.focused-row + 1);
                return accept;
            }
            
            if (event.text == Key.LeftArrow) {
                if (root.focused-row == 0) { root.focused-col-0 = Math.max(0, root.focused-col-0 - 1); }
                else if (root.focused-row == 1) { root.focused-col-1 = Math.max(0, root.focused-col-1 - 1); }
                else if (root.focused-row == 2) { root.focused-col-2 = Math.max(0, root.focused-col-2 - 1); }
                return accept;
            }
            if (event.text == Key.RightArrow) {
                if (root.focused-row == 0) { root.focused-col-0 = Math.min(5, root.focused-col-0 + 1); }
                else if (root.focused-row == 1) { root.focused-col-1 = Math.min(5, root.focused-col-1 + 1); }
                else if (root.focused-row == 2) { root.focused-col-2 = Math.min(9, root.focused-col-2 + 1); }
                return accept;
            }
            
            if (event.text == Key.Return) {
                if (root.focused-row == 0) {
                    if (root.focused-col-0 == 0) { root.back-clicked(); }
                    else if (root.focused-col-0 == 1) { root.active-tab = "home"; }
                    else if (root.focused-col-0 == 2) { root.active-tab = "store"; }
                    else if (root.focused-col-0 == 3) { root.active-tab = "files"; }
                    else if (root.focused-col-0 == 4) { root.active-tab = "console"; }
                    else if (root.focused-col-0 == 5) { root.show-settings = true; root.settings-focused-row = 0; }
                }
                else if (root.focused-row == 1) {
                    if (root.core-apps[root.focused-col-1].action-id == "Settings") { root.show-settings = true; root.settings-focused-row = 0; }
                    else { root.app-clicked(root.core-apps[root.focused-col-1].action-id); }
                }
                else if (root.focused-row == 2) {
                    root.app-clicked(root.installed-apps[root.focused-col-2].action-id);
                }
                else if (root.focused-row == 3) {
                    root.back-clicked();
                }
                return accept;
            }
            
            return reject;
        }
    }
    
    init => { fs.focus(); }
    
    // LAYOUT COMPOSITION
    VerticalLayout {
        padding-left: TvSpacing.padding-xxl;
        padding-right: TvSpacing.padding-xxl;
        padding-top: TvSpacing.padding-lg;
        padding-bottom: TvSpacing.padding-lg;
        spacing: TvSpacing.space-xl;
        alignment: start;
        
        // Ribbon TopBar
        TopBar {
            active-tab <=> root.active-tab;
            focused-col: root.focused-col-0;
            row-focused: root.focused-row == 0;
            current-time: root.current-time;
            wifi-enabled: root.wifi-enabled;
            bluetooth-enabled: root.bluetooth-enabled;
            
            tab-changed(tab) => { root.active-tab = tab; }
            back-clicked => { root.back-clicked(); }
            settings-clicked => { root.show-settings = true; root.settings-focused-row = 0; }
        }
        
        // Tab Content Router Panel
        if (root.active-tab == "home") : VerticalLayout {
            spacing: TvSpacing.space-xxl;
            alignment: start;
            
            // Row 1: Core System Applications
            AppGrid {
                title: "أدوات النظام الأساسية";
                apps: root.core-apps;
                focused-index: root.focused-col-1;
                active: root.focused-row == 1;
                is-sliding: false;
                app-clicked(id) => {
                    if (id == "Settings") { root.show-settings = true; root.settings-focused-row = 0; }
                    else { root.app-clicked(id); }
                }
            }
            
            // Row 2: Installed User apps (Cinematic sliding carousel)
            AppGrid {
                title: "البرامج والترفيه المثبتة";
                apps: root.installed-apps;
                focused-index: root.focused-col-2;
                active: root.focused-row == 2;
                is-sliding: true;
                app-clicked(id) => { root.app-clicked(id); }
            }
        }
        
        // Sub-showcases representing dynamic tabs elegantly
        if (root.active-tab == "store") : VerticalLayout {
            alignment: center;
            spacing: TvSpacing.space-xl;
            Text {
                text: "حقيبة تطبيقات Sumer OS";
                font-family: TvTypography.font-family;
                font-size: TvTypography.font-size-xxl;
                font-weight: TvTypography.font-weight-bold;
                color: TvColors.accent;
                horizontal-alignment: center;
            }
            AppCard {
                width: 400px;
                height-ratio: 0.5;
                text: "🛍️ فتح متجر زاكورة";
                card-background: TvColors.store-bg;
                is-focused: root.focused-row == 1;
                clicked => { root.app-clicked("Store"); }
            }
        }
        
        if (root.active-tab == "files") : VerticalLayout {
            alignment: center;
            spacing: TvSpacing.space-xl;
            Text {
                text: "مدير الملفات الكوني";
                font-family: TvTypography.font-family;
                font-size: TvTypography.font-size-xxl;
                font-weight: TvTypography.font-weight-bold;
                color: TvColors.accent;
                horizontal-alignment: center;
            }
            AppCard {
                width: 400px;
                height-ratio: 0.5;
                text: "📂 استعراض الملفات";
                card-background: TvColors.files-bg;
                is-focused: root.focused-row == 1;
                clicked => { root.app-clicked("Files"); }
            }
        }
        
        if (root.active-tab == "console") : VerticalLayout {
            alignment: center;
            spacing: TvSpacing.space-xl;
            Text {
                text: "منفذ الأوامر الفوري - شيل دجلة";
                font-family: TvTypography.font-family;
                font-size: TvTypography.font-size-xxl;
                font-weight: TvTypography.font-weight-bold;
                color: TvColors.console-text;
                horizontal-alignment: center;
            }
            AppCard {
                width: 400px;
                height-ratio: 0.5;
                text: "💻 تشغيل شيل دجلة";
                card-background: TvColors.console-bg;
                text-color: TvColors.console-text;
                is-focused: root.focused-row == 1;
                clicked => { root.app-clicked("Console"); }
            }
        }
        
        // Bottom Exit / Back Button
        Rectangle {
            height: 48px;
            border-radius: TvSpacing.radius-md;
            background: root.focused-row == 3 ? TvColors.shutdown-bg.with-alpha(0.2) : TvColors.border-default;
            border-width: root.focused-row == 3 ? 2.5px : 1px;
            border-color: root.focused-row == 3 ? TvColors.shutdown-bg : TvColors.border-default;
            
            HorizontalLayout {
                alignment: center;
                Text {
                    text: "🛑 خروج والعودة للواجهة الرئيسية";
                    font-family: TvTypography.font-family;
                    font-weight: TvTypography.font-weight-bold;
                    color: root.focused-row == 3 ? TvColors.shutdown-bg : TvColors.text-secondary;
                    vertical-alignment: center;
                }
            }
            TouchArea { clicked => { root.back-clicked(); } }
        }
    }
    
    // FULL-SCREEN SLIDING DRAWERS & POPUPS
    
    // Left Configuration Panel
    SettingsPanel {
        show-settings <=> root.show-settings;
        settings-page <=> root.settings-page;
        settings-focused-row <=> root.settings-focused-row;
        subpage-focused-row <=> root.subpage-focused-row;
        system-volume <=> root.system-volume;
        wifi-enabled <=> root.wifi-enabled;
        airplane-mode <=> root.airplane-mode;
        bluetooth-enabled <=> root.bluetooth-enabled;
        bluetooth-connecting <=> root.bluetooth-connecting;
        bluetooth-connection-status <=> root.bluetooth-connection-status;
        system-brightness <=> root.system-brightness;
        perf-mode <=> root.perf-mode;
        camera-enabled <=> root.camera-enabled;
        mic-enabled <=> root.mic-enabled;
        location-enabled <=> root.location-enabled;
        screensaver-timeout <=> root.screensaver-timeout;
        screensaver-image-mode <=> root.screensaver-image-mode;
        screensaver-sub-page <=> root.screensaver-sub-page;
        
        close-requested => { root.show-settings = false; }
        volume-clicked => { root.show-volume-bar = true; root.trigger-volume-timer(); }
        brightness-clicked => { root.show-brightness-bar = true; root.trigger-brightness-timer(); }
        wifi-network-clicked(net) => { root.wifi-network-clicked(net); }
        bluetooth-device-clicked(dev) => { root.bluetooth-device-clicked(dev); }
        settings-page-changed(pg) => { root.settings-page = pg; }
    }
    
    // Pop-up overlays (Volume & Brightness bars)
    VerticalLayout {
        width: 100%;
        height: 100%;
        alignment: end;
        padding-bottom: 48px;
        
        if (root.show-volume-bar) : HorizontalLayout {
            alignment: center;
            VolumeBar {
                system-volume: root.system-volume;
                is-visible: true;
                clicked => { root.show-volume-bar = false; }
            }
        }
        
        if (root.show-brightness-bar) : HorizontalLayout {
            alignment: center;
            BrightnessBar {
                system-brightness: root.system-brightness;
                is-visible: true;
                clicked => { root.show-brightness-bar = false; }
            }
        }
    }
    
    // Bluetooth Connection Simulation Full-screen Overlay
    if (root.bluetooth-connecting) : Rectangle {
        width: 100%;
        height: 100%;
        background: TvColors.bluetooth-connecting-bg;
        z: 30;
        
        VerticalLayout {
            alignment: center;
            spacing: TvSpacing.space-xxl;
            
            Text {
                text: "🔵";
                font-size: TvTypography.font-size-giant;
                horizontal-alignment: center;
            }
            
            Text {
                text: root.bluetooth-connection-status;
                font-family: TvTypography.font-family;
                font-size: TvTypography.font-size-xl;
                font-weight: TvTypography.font-weight-bold;
                color: TvColors.bluetooth-connecting-blue;
                horizontal-alignment: center;
            }
            
            Text {
                text: "يرجى تشغيل وضع الاقتران في جهازك...";
                font-family: TvTypography.font-family;
                font-size: TvTypography.font-size-base;
                color: TvColors.bluetooth-connecting-text;
                horizontal-alignment: center;
            }
        }
    }
    
    callback wifi-network-clicked(string);
}
