import { GlassCard } from "../components/glass_card.slint";
import { ActionButton } from "../components/action_button.slint";

export component SecretVaultView inherits Rectangle {
    // Theme Colors
    in property <color> bg-dark: #070a13;
    in property <color> bg-card: rgba(15, 23, 42, 0.45);
    in property <color> theme-border-color: rgba(30, 41, 59, 0.6);
    in property <color> accent-color: #6366f1;
    in property <color> accent-hover: #4f46e5;
    in property <color> accent-glow: rgba(99, 102, 241, 0.15);
    in property <color> text-primary: #f1f5f9;
    in property <color> text-secondary: #94a3b8;
    in property <color> text-muted: #64748b;
    in property <color> green-color: #10b981;
    in property <color> red-color: #ef4444;

    // Vault States
    property <bool> vault-unlocked: false;
    property <string> entered-pin: "";
    property <int> entered-pin-len: 0;
    property <string> vault-log: "الخزنة مشفرة بمفتاح AES-256";

    // Vault Files
    property <bool> has-doc1: true;
    property <bool> has-doc2: true;
    property <bool> has-doc3: true;

    HorizontalLayout {
        spacing: 16px;
        padding: 24px;

        // Main Vault Area
        VerticalLayout {
            horizontal-stretch: 1;
            spacing: 14px;

            Text {
                text: "خزنة الملفات السرية والمشفرة";
                color: text-primary;
                font-size: 14px;
                font-weight: 700;
                horizontal-alignment: right;
            }

            // Locked state gate
            if !vault-unlocked : GlassCard {
                vertical-stretch: 1;
                
                VerticalLayout {
                    padding: 32px;
                    spacing: 20px;
                    alignment: center;

                    // Padlock Icon
                    HorizontalLayout {
                        alignment: center;
                        Rectangle {
                            width: 80px; height: 80px; border-radius: 40px;
                            background: rgba(239, 68, 68, 0.1);
                            border-width: 1px; border-color: rgba(239, 68, 68, 0.3);
                            
                            Text {
                                text: "🔒";
                                font-size: 36px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Vault Description
                    VerticalLayout {
                        spacing: 6px;
                        Text {
                            text: "الخزنة السرية المقفلة";
                            color: text-primary;
                            font-size: 16px;
                            font-weight: 800;
                            horizontal-alignment: center;
                        }
                        Text {
                            text: "هذا المجلد مشفر تماماً على الهاتف ولا يمكن فتحه إلا بإدخال كلمة السر الخاصة بك.";
                            color: text-secondary;
                            font-size: 11px;
                            horizontal-alignment: center;
                            wrap: word-wrap;
                        }
                        Text {
                            text: "[ تلميح: الرمز الافتراضي للخزنة هو 2026 ]";
                            color: accent-color;
                            font-size: 10px;
                            font-weight: 700;
                            horizontal-alignment: center;
                        }
                    }

                    // PIN display dots
                    HorizontalLayout {
                        alignment: center;
                        spacing: 12px;
                        for i in [1, 2, 3, 4] : Rectangle {
                            width: 16px; height: 16px; border-radius: 8px;
                            background: entered-pin-len >= i ? red-color : rgba(255, 255, 255, 0.1);
                            border-width: 1px; border-color: entered-pin-len >= i ? red-color : theme-border-color;
                        }
                    }

                    // Keypad grid
                    VerticalLayout {
                        spacing: 8px;
                        
                        HorizontalLayout {
                            spacing: 12px; alignment: center;
                            for num in ["3", "2", "1"] : Rectangle {
                                width: 50px; height: 36px; border-radius: 6px; background: rgba(255, 255, 255, 0.05);
                                Text { text: num; color: text-primary; font-size: 14px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                                TouchArea { clicked => { if (entered-pin-len < 4) { entered-pin = entered-pin + num; entered-pin-len = entered-pin-len + 1; } } }
                            }
                        }
                        HorizontalLayout {
                            spacing: 12px; alignment: center;
                            for num in ["6", "5", "4"] : Rectangle {
                                width: 50px; height: 36px; border-radius: 6px; background: rgba(255, 255, 255, 0.05);
                                Text { text: num; color: text-primary; font-size: 14px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                                TouchArea { clicked => { if (entered-pin-len < 4) { entered-pin = entered-pin + num; entered-pin-len = entered-pin-len + 1; } } }
                            }
                        }
                        HorizontalLayout {
                            spacing: 12px; alignment: center;
                            for num in ["9", "8", "7"] : Rectangle {
                                width: 50px; height: 36px; border-radius: 6px; background: rgba(255, 255, 255, 0.05);
                                Text { text: num; color: text-primary; font-size: 14px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                                TouchArea { clicked => { if (entered-pin-len < 4) { entered-pin = entered-pin + num; entered-pin-len = entered-pin-len + 1; } } }
                            }
                        }
                        HorizontalLayout {
                            spacing: 12px; alignment: center;
                            // Clear
                            Rectangle {
                                width: 50px; height: 36px; border-radius: 6px; background: rgba(239, 68, 68, 0.15);
                                Text { text: "C"; color: red-color; font-size: 12px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                                TouchArea { clicked => { entered-pin = ""; entered-pin-len = 0; vault-log = "تم مسح الرمز المدخل"; } }
                            }
                            // Zero
                            Rectangle {
                                width: 50px; height: 36px; border-radius: 6px; background: rgba(255, 255, 255, 0.05);
                                Text { text: "0"; color: text-primary; font-size: 14px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                                TouchArea { clicked => { if (entered-pin-len < 4) { entered-pin = entered-pin + "0"; entered-pin-len = entered-pin-len + 1; } } }
                            }
                            // Unlock Action
                            Rectangle {
                                width: 50px; height: 36px; border-radius: 6px; background: rgba(16, 185, 129, 0.2);
                                Text { text: "🔓"; font-size: 14px; horizontal-alignment: center; vertical-alignment: center; }
                                TouchArea {
                                    clicked => {
                                        if (entered-pin == "2026") {
                                            vault-unlocked = true;
                                            entered-pin = "";
                                            entered-pin-len = 0;
                                            vault-log = "تم فك التشفير بنجاح ودخول الخزنة!";
                                        } else {
                                            entered-pin = "";
                                            entered-pin-len = 0;
                                            vault-log = "رمز PIN خاطئ! تفشل محاولة الدخول.";
                                        }
                                    }
                                }
                            }
                        }
                    }

                    Text {
                        text: vault-log;
                        color: vault-log == "رمز PIN خاطئ! تفشل محاولة الدخول." ? red-color : green-color;
                        font-size: 10px;
                        font-weight: 700;
                        horizontal-alignment: center;
                    }
                }
            }

            // Unlocked state view
            if vault-unlocked : GlassCard {
                vertical-stretch: 1;
                
                VerticalLayout {
                    padding: 16px;
                    spacing: 12px;

                    // Unlocked header
                    HorizontalLayout {
                        alignment: space-between;
                        
                        ActionButton {
                            text: "قفل الخزنة وتشفيرها";
                            icon: "🔒";
                            base-bg: red-color;
                            hover-bg: red-color.darker(10%);
                            clicked => {
                                vault-unlocked = false;
                                vault-log = "الخزنة مقفلة ومشفرة بمفتاح AES-256";
                            }
                        }

                        HorizontalLayout {
                            spacing: 8px;
                            alignment: end;
                            Text {
                                text: "الخزنة مفتوحة ونشطة";
                                color: green-color;
                                font-size: 13px;
                                font-weight: 700;
                                vertical-alignment: center;
                            }
                            Text {
                                text: "🔓";
                                font-size: 18px;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Encrypted log status
                    Text {
                        text: vault-log;
                        color: green-color;
                        font-size: 9px;
                        font-weight: 700;
                        horizontal-alignment: right;
                    }

                    // Vault Files List
                    VerticalLayout {
                        spacing: 8px;

                        // Doc 1
                        if has-doc1 : GlassCard {
                            height: 48px;
                            card-bg: rgba(0, 0, 0, 0.2);
                            HorizontalLayout {
                                padding: 8px;
                                alignment: space-between;

                                HorizontalLayout {
                                    spacing: 8px;
                                    ActionButton {
                                        text: "تصدير للكمبيوتر"; icon: "📥";
                                        clicked => { vault-log = "تم فك تشفير وتصدير: بطاقة_الهوية.pdf للكمبيوتر"; }
                                    }
                                    ActionButton {
                                        text: "حذف"; icon: "🗑️"; base-bg: red-color;
                                        clicked => { has-doc1 = false; vault-log = "تم حذف الملف المشفر نهائياً"; }
                                    }
                                }

                                HorizontalLayout {
                                    spacing: 10px;
                                    alignment: end;
                                    VerticalLayout {
                                        alignment: center;
                                        Text { text: "بطاقة_الهوية_الوطنية.pdf"; color: text-primary; font-size: 10px; font-weight: 700; horizontal-alignment: right; }
                                        Text { text: "2.4 MB • مشفر AES"; color: text-muted; font-size: 7px; horizontal-alignment: right; }
                                    }
                                    Text { text: "📄"; font-size: 18px; vertical-alignment: center; }
                                }
                            }
                        }

                        // Doc 2
                        if has-doc2 : GlassCard {
                            height: 48px;
                            card-bg: rgba(0, 0, 0, 0.2);
                            HorizontalLayout {
                                padding: 8px;
                                alignment: space-between;

                                HorizontalLayout {
                                    spacing: 8px;
                                    ActionButton {
                                        text: "تصدير للكمبيوتر"; icon: "📥";
                                        clicked => { vault-log = "تم فك تشفير وتصدير: عقد_الملكية.docx للكمبيوتر"; }
                                    }
                                    ActionButton {
                                        text: "حذف"; icon: "🗑️"; base-bg: red-color;
                                        clicked => { has-doc2 = false; vault-log = "تم حذف الملف المشفر نهائياً"; }
                                    }
                                }

                                HorizontalLayout {
                                    spacing: 10px;
                                    alignment: end;
                                    VerticalLayout {
                                        alignment: center;
                                        Text { text: "عقد_ملكية_المنزل.docx"; color: text-primary; font-size: 10px; font-weight: 700; horizontal-alignment: right; }
                                        Text { text: "1.1 MB • مشفر AES"; color: text-muted; font-size: 7px; horizontal-alignment: right; }
                                    }
                                    Text { text: "📝"; font-size: 18px; vertical-alignment: center; }
                                }
                            }
                        }

                        // Doc 3
                        if has-doc3 : GlassCard {
                            height: 48px;
                            card-bg: rgba(0, 0, 0, 0.2);
                            HorizontalLayout {
                                padding: 8px;
                                alignment: space-between;

                                HorizontalLayout {
                                    spacing: 8px;
                                    ActionButton {
                                        text: "تصدير للكمبيوتر"; icon: "📥";
                                        clicked => { vault-log = "تم فك تشفير وتصدير: صورة_عائلية.jpg للكمبيوتر"; }
                                    }
                                    ActionButton {
                                        text: "حذف"; icon: "🗑️"; base-bg: red-color;
                                        clicked => { has-doc3 = false; vault-log = "تم حذف الملف المشفر نهائياً"; }
                                    }
                                }

                                HorizontalLayout {
                                    spacing: 10px;
                                    alignment: end;
                                    VerticalLayout {
                                        alignment: center;
                                        Text { text: "نسخة_احتياطية_صورة_سرية.jpg"; color: text-primary; font-size: 10px; font-weight: 700; horizontal-alignment: right; }
                                        Text { text: "4.3 MB • مشفر AES"; color: text-muted; font-size: 7px; horizontal-alignment: right; }
                                    }
                                    Text { text: "📷"; font-size: 18px; vertical-alignment: center; }
                                }
                            }
                        }
                    }

                    // Add new file row
                    ActionButton {
                        text: "تشفير ملف جديد وإضافته للخزنة السرية";
                        icon: "➕";
                        base-bg: accent-color;
                        hover-bg: accent-hover;
                        clicked => {
                            if (!has-doc1) { has-doc1 = true; }
                            else if (!has-doc2) { has-doc2 = true; }
                            else if (!has-doc3) { has-doc3 = true; }
                            vault-log = "تم اختيار ملف من الحاسوب وتشفيره بـ AES-256 ورفعه للخزنة";
                        }
                    }
                }
            }
        }
    }
}
