import { ScrollView } from "std-widgets.slint";

// Custom Sleek Button
component GlassButton {
    in property <string> text;
    in property <string> icon;
    in property <bool> danger: false;
    callback clicked();

    Rectangle {
        height: 38px;
        background: danger ? (ta.has-hover ? #ef444422 : #ef44440c) : (ta.has-hover ? #ffffff0d : #ffffff04);
        border-radius: 8px;
        border-width: 1px;
        border-color: danger ? (ta.has-hover ? #ef4444 : #ef444440) : (ta.has-hover ? #ffffff20 : #ffffff10);
        
        animate background, border-color { duration: 150ms; }

        ta := TouchArea {
            clicked => { root.clicked(); }
        }

        HorizontalLayout {
            padding-left: 12px;
            padding-right: 12px;
            spacing: 6px;
            alignment: center;

            if icon != "" : Text {
                text: icon;
                font-size: 14px;
                vertical-alignment: center;
            }
            Text {
                text: text;
                font-size: 13px;
                font-family: "Outfit";
                font-weight: 600;
                color: danger ? #f87171 : #f1f5f9;
                vertical-alignment: center;
            }
        }
    }
}

// Custom Tool Selection Button
component ToolButton {
    in property <string> text;
    in property <string> icon;
    in property <bool> active;
    callback clicked();

    Rectangle {
        height: 42px;
        background: active ? #3b82f625 : (ta.has-hover ? #ffffff0a : transparent);
        border-radius: 8px;
        border-width: 1px;
        border-color: active ? #3b82f6 : (ta.has-hover ? #ffffff1a : #ffffff05);
        
        animate background, border-color { duration: 150ms; }

        ta := TouchArea {
            clicked => { root.clicked(); }
        }

        HorizontalLayout {
            padding-left: 12px;
            padding-right: 12px;
            spacing: 8px;
            alignment: start;

            Text {
                text: icon;
                font-size: 16px;
                vertical-alignment: center;
            }
            Text {
                text: text;
                font-size: 13px;
                font-family: "Outfit";
                font-weight: active ? 700 : 500;
                color: active ? #ffffff : #94a3b8;
                vertical-alignment: center;
            }
        }
    }
}

// Custom Color Preset Button
component ColorPaletteButton {
    in property <color> color-val;
    callback clicked();

    Rectangle {
        width: 26px;
        height: 26px;
        border-radius: 6px;
        background: color-val;
        border-width: 1px;
        border-color: ta.has-hover ? #ffffffaa : #ffffff20;
        
        animate border-color { duration: 100ms; }

        ta := TouchArea {
            clicked => { root.clicked(); }
        }
    }
}

// Custom Sleek Slider
component SleekSlider {
    in property <string> label;
    in-out property <float> value; // 0.0 to 1.0
    in property <float> min: 0.0;
    in property <float> max: 1.0;
    in property <bool> is-int: false;

    callback changed(float);

    VerticalLayout {
        spacing: 4px;
        
        HorizontalLayout {
            alignment: space-between;
            Text {
                text: root.label;
                font-size: 11px;
                color: #94a3b8;
                font-family: "Outfit";
            }
            Text {
                text: root.is-int ? ("" + Math.round(root.value)) : ("" + (Math.round(root.value * 100) / 100));
                font-size: 11px;
                color: #3b82f6;
                font-family: "Outfit";
                font-weight: 700;
            }
        }
        
        Rectangle {
            height: 16px;
            
            // Slider Track background
            Rectangle {
                y: (parent.height - self.height) / 2;
                height: 4px;
                background: #1e293b;
                border-radius: 2px;
                width: 100%;
                
                // Filled progress track
                Rectangle {
                    x: 0;
                    width: parent.width * ((root.value - root.min) / (root.max - root.min));
                    height: 100%;
                    background: @linear-gradient(90deg, #3b82f6, #8b5cf6);
                    border-radius: 2px;
                }
            }

            // Slider Handle
            handle := Rectangle {
                x: parent.width * ((root.value - root.min) / (root.max - root.min)) - self.width / 2;
                y: (parent.height - self.height) / 2;
                width: 12px;
                height: 12px;
                border-radius: 6px;
                background: #ffffff;
                border-width: 1px;
                border-color: #3b82f6;
                
                drop-shadow-color: #3b82f680;
                drop-shadow-blur: 4px;
            }

            TouchArea {
                width: 100%;
                height: 100%;
                
                moved => {
                    root.value = Math.max(root.min, Math.min(root.max, (self.mouse-x / self.width) * (root.max - root.min) + root.min));
                    root.changed(root.value);
                }
                clicked => {
                    root.value = Math.max(root.min, Math.min(root.max, (self.mouse-x / self.width) * (root.max - root.min) + root.min));
                    root.changed(root.value);
                }
            }
        }
    }
}

// Main Window
export component AppWindow inherits Window {
    title: "Kispu Painter | رسام كيسبو";
    width: 1150px;
    height: 750px;
    background: @linear-gradient(135deg, #050914 0%, #0a1128 50%, #03060f 100%);
    default-font-family: "Outfit";

    // --- State Properties ---
    in-out property <image> canvas-image;
    in-out property <int> canvas-width: 32;
    in-out property <int> canvas-height: 32;
    in-out property <bool> grid-enabled: true;
    in-out property <float> zoom-factor: 12.0;

    // Active tool state
    in-out property <string> active-tool: "pencil"; // pencil, eraser, fill, dropper, line, rect, circle
    in-out property <float> brush-size: 1.0;
    in-out property <string> symmetry-mode: "none"; // none, vertical, horizontal, both
    in-out property <bool> fill-shapes: false;
    in-out property <bool> is-pixel-art: true;

    // Custom Color RGB values (0.0 to 1.0)
    in-out property <float> color-r: 0.0;
    in-out property <float> color-g: 0.0;
    in-out property <float> color-b: 0.0;
    in-out property <float> color-a: 1.0;

    // Computed Slint color for preview
    property <color> current-color: rgba(color-r * 255.0, color-g * 255.0, color-b * 255.0, color-a);

    // Layer states
    in-out property <bool> layer1-visible: true;
    in-out property <bool> layer2-visible: true;
    in-out property <float> layer1-opacity: 1.0;
    in-out property <float> layer2-opacity: 1.0;
    in-out property <int> active-layer: 1; // 0 for Layer 1, 1 for Layer 2 (top)

    // Status / Help message
    in-out property <string> status-text: "جاهز للرسم";
    in-out property <int> cursor-x: -1;
    in-out property <int> cursor-y: -1;

    // Resolution index: 0=16, 1=32, 2=64, 3=128, 4=256, 5=512
    in-out property <int> size-index: 1;

    // --- Callbacks to Rust ---
    callback pointer-event(string, length, length, length, length); // event_kind, mouse_x, mouse_y, width, height
    callback change-tool(string);
    callback change-symmetry(string);
    callback change-color(int, int, int, int); // r, g, b, a (0-255)
    callback toggle-layer-visibility(int, bool); // layer_idx, visible
    callback change-layer-opacity(int, float); // layer_idx, opacity
    callback change-active-layer(int); // layer_idx
    callback clear-canvas();
    callback resize-canvas(int); // size_index
    callback undo();
    callback redo();
    callback save-image();
    callback open-image();

    // Top-level Vertical Layout
    VerticalLayout {
        padding: 16px;
        spacing: 12px;

        // 1. TOP HEADER BAR
        Rectangle {
            height: 60px;
            background: #ffffff03;
            border-radius: 12px;
            border-width: 1px;
            border-color: #ffffff0d;

            HorizontalLayout {
                padding-left: 16px;
                padding-right: 16px;
                alignment: space-between;

                // LEFT: File operations & Undo/Redo
                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;
                    
                    GlassButton {
                        text: "تحميل (Open)";
                        icon: "📁";
                        clicked => { root.open-image(); }
                    }
                    GlassButton {
                        text: "حفظ (Save)";
                        icon: "💾";
                        clicked => { root.save-image(); }
                    }

                    // Vertical Divider
                    Rectangle { width: 1px; height: 30px; background: #ffffff1a; y: (parent.height - self.height)/2; }

                    GlassButton {
                        text: "تراجع";
                        icon: "↩️";
                        clicked => { root.undo(); }
                    }
                    GlassButton {
                        text: "تكرار";
                        icon: "↪️";
                        clicked => { root.redo(); }
                    }
                    
                    GlassButton {
                        text: "مسح Canvas";
                        icon: "🗑️";
                        danger: true;
                        clicked => { root.clear-canvas(); }
                    }
                }

                // CENTER: Mode Selector (Pixel Art vs Sketch)
                HorizontalLayout {
                    alignment: center;
                    
                    Rectangle {
                        width: 240px;
                        height: 38px;
                        background: #0f172a80;
                        border-radius: 19px;
                        border-width: 1px;
                        border-color: #ffffff10;
                        y: (parent.height - self.height)/2;

                        HorizontalLayout {
                            padding: 3px;
                            spacing: 4px;

                            // Pixel Art Mode Tab
                            Rectangle {
                                horizontal-stretch: 1;
                                border-radius: 16px;
                                background: root.is-pixel-art ? @linear-gradient(135deg, #3b82f6, #8b5cf6) : transparent;
                                
                                animate background { duration: 150ms; }

                                ta-pixel := TouchArea {
                                    clicked => {
                                        root.is-pixel-art = true;
                                        root.grid-enabled = true;
                                        root.zoom-factor = 12.0;
                                    }
                                }

                                Text {
                                    text: "بكسل آرت (Pixel)";
                                    font-size: 11px;
                                    font-weight: root.is-pixel-art ? 700 : 500;
                                    color: root.is-pixel-art ? #ffffff : #94a3b8;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }

                            // Sketch Mode Tab
                            Rectangle {
                                horizontal-stretch: 1;
                                border-radius: 16px;
                                background: !root.is-pixel-art ? @linear-gradient(135deg, #3b82f6, #8b5cf6) : transparent;

                                animate background { duration: 150ms; }

                                ta-sketch := TouchArea {
                                    clicked => {
                                        root.is-pixel-art = false;
                                        root.grid-enabled = false;
                                        root.zoom-factor = 2.0;
                                    }
                                }

                                Text {
                                    text: "رسم حر (Sketch)";
                                    font-size: 11px;
                                    font-weight: !root.is-pixel-art ? 700 : 500;
                                    color: !root.is-pixel-art ? #ffffff : #94a3b8;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }

                // RIGHT: App Title & Logo
                HorizontalLayout {
                    spacing: 12px;
                    alignment: end;
                    
                    VerticalLayout {
                        alignment: center;
                        Text {
                            text: "رسام كيسبو KISPU PAINTER";
                            font-size: 14px;
                            font-weight: 800;
                            color: #ffffff;
                            horizontal-alignment: right;
                        }
                        Text {
                            text: "نظام تشغيل سومر | Sumer OS";
                            font-size: 10px;
                            color: #3b82f6;
                            horizontal-alignment: right;
                        }
                    }

                    // Logo Icon Box
                    Rectangle {
                        width: 38px;
                        height: 38px;
                        border-radius: 10px;
                        background: @linear-gradient(135deg, #3b82f6, #8b5cf6);
                        y: (parent.height - self.height)/2;

                        Text {
                            text: "🎨";
                            font-size: 18px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }

        // 2. MAIN WORKSPACE CONTENT
        HorizontalLayout {
            spacing: 12px;

            // --- LEFT COLUMN: DRAWING TOOLS PANEL ---
            Rectangle {
                width: 240px;
                background: #ffffff03;
                border-radius: 12px;
                border-width: 1px;
                border-color: #ffffff0d;

                VerticalLayout {
                    padding: 14px;
                    spacing: 14px;
                    alignment: start;

                    Text {
                        text: "أدوات الرسم (Tools)";
                        font-size: 13px;
                        font-weight: 700;
                        color: #ffffff;
                        horizontal-alignment: right;
                    }

                    // Tool list grid
                    VerticalLayout {
                        spacing: 6px;

                        ToolButton {
                            text: "قلم الرسم (Pencil)";
                            icon: "✏️";
                            active: root.active-tool == "pencil";
                            clicked => { root.active-tool = "pencil"; root.change-tool("pencil"); }
                        }
                        ToolButton {
                            text: "ممحاة الألوان (Eraser)";
                            icon: "🧼";
                            active: root.active-tool == "eraser";
                            clicked => { root.active-tool = "eraser"; root.change-tool("eraser"); }
                        }
                        ToolButton {
                            text: "ملء المساحات (Bucket)";
                            icon: "🪣";
                            active: root.active-tool == "fill";
                            clicked => { root.active-tool = "fill"; root.change-tool("fill"); }
                        }
                        ToolButton {
                            text: "قطارة الألوان (Dropper)";
                            icon: "🔍";
                            active: root.active-tool == "dropper";
                            clicked => { root.active-tool = "dropper"; root.change-tool("dropper"); }
                        }
                        
                        // Shapes
                        ToolButton {
                            text: "رسم خط مستقيم (Line)";
                            icon: "📏";
                            active: root.active-tool == "line";
                            clicked => { root.active-tool = "line"; root.change-tool("line"); }
                        }
                        ToolButton {
                            text: "رسم مستطيل (Rect)";
                            icon: "⬜";
                            active: root.active-tool == "rect";
                            clicked => { root.active-tool = "rect"; root.change-tool("rect"); }
                        }
                        ToolButton {
                            text: "رسم دائرة (Circle)";
                            icon: "⚪";
                            active: root.active-tool == "circle";
                            clicked => { root.active-tool = "circle"; root.change-tool("circle"); }
                        }
                    }

                    // Fill shapes setting (for Rect and Circle)
                    if root.active-tool == "rect" || root.active-tool == "circle" : HorizontalLayout {
                        alignment: space-between;
                        Text {
                            text: "تعبئة الشكل (Fill Shape)";
                            font-size: 12px;
                            color: #94a3b8;
                            vertical-alignment: center;
                        }
                        // Simple custom toggle switch
                        Rectangle {
                            width: 36px;
                            height: 20px;
                            border-radius: 10px;
                            background: root.fill-shapes ? #10b981 : #1e293b;
                            
                            animate background { duration: 150ms; }

                            Rectangle {
                                x: root.fill-shapes ? 18px : 2px;
                                y: 2px;
                                width: 16px;
                                height: 16px;
                                border-radius: 8px;
                                background: #ffffff;
                                
                                animate x { duration: 150ms; }
                            }
                            TouchArea {
                                clicked => { root.fill-shapes = !root.fill-shapes; }
                            }
                        }
                    }

                    // Brush Size Slider
                    brush-slider := SleekSlider {
                        label: "حجم الفرشاة (Brush Size)";
                        value: root.brush-size;
                        min: 1;
                        max: 16;
                        is-int: true;
                        changed(val) => {
                            root.brush-size = Math.round(val);
                        }
                    }

                    // Horizontal Divider
                    Rectangle { height: 1px; background: #ffffff0d; }

                    // Symmetry Section
                    Text {
                        text: "التماثل / المرآة (Symmetry)";
                        font-size: 12px;
                        font-weight: 700;
                        color: #ffffff;
                        horizontal-alignment: right;
                    }
                    
                    HorizontalLayout {
                        spacing: 4px;
                        
                        sym-none := Rectangle {
                            horizontal-stretch: 1;
                            height: 30px;
                            background: root.symmetry-mode == "none" ? #3b82f625 : #ffffff03;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: root.symmetry-mode == "none" ? #3b82f6 : #ffffff10;
                            
                            TouchArea { clicked => { root.symmetry-mode = "none"; root.change-symmetry("none"); } }
                            Text { text: "❌"; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                        }
                        
                        sym-vert := Rectangle {
                            horizontal-stretch: 1;
                            height: 30px;
                            background: root.symmetry-mode == "vertical" ? #3b82f625 : #ffffff03;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: root.symmetry-mode == "vertical" ? #3b82f6 : #ffffff10;
                            
                            TouchArea { clicked => { root.symmetry-mode = "vertical"; root.change-symmetry("vertical"); } }
                            Text { text: "Vertical ➡️⬅️"; font-size: 9px; horizontal-alignment: center; vertical-alignment: center; color: #ffffff; }
                        }

                        sym-horiz := Rectangle {
                            horizontal-stretch: 1;
                            height: 30px;
                            background: root.symmetry-mode == "horizontal" ? #3b82f625 : #ffffff03;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: root.symmetry-mode == "horizontal" ? #3b82f6 : #ffffff10;
                            
                            TouchArea { clicked => { root.symmetry-mode = "horizontal"; root.change-symmetry("horizontal"); } }
                            Text { text: "Horizontal ⬆️⬇️"; font-size: 9px; horizontal-alignment: center; vertical-alignment: center; color: #ffffff; }
                        }
                    }
                }
            }

            // --- CENTER COLUMN: MAIN DRAWING CANVAS ---
            VerticalLayout {
                horizontal-stretch: 1;
                spacing: 12px;

                // Zoom control bar
                Rectangle {
                    height: 44px;
                    background: #ffffff03;
                    border-radius: 8px;
                    border-width: 1px;
                    border-color: #ffffff0d;

                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        alignment: space-between;

                        HorizontalLayout {
                            spacing: 8px;
                            alignment: start;
                            
                            Text {
                                text: "تكبير (Zoom):";
                                font-size: 12px;
                                color: #94a3b8;
                                vertical-alignment: center;
                            }
                            
                            zoom-slider := SleekSlider {
                                width: 140px;
                                value: root.zoom-factor;
                                min: 1.0;
                                max: 32.0;
                                changed(val) => {
                                    root.zoom-factor = val;
                                }
                            }

                            GlassButton {
                                text: "100%";
                                clicked => { root.zoom-factor = root.is-pixel-art ? 12.0 : 1.0; zoom-slider.value = root.zoom-factor; }
                            }
                        }

                        HorizontalLayout {
                            spacing: 12px;
                            alignment: end;

                            if root.is-pixel-art : HorizontalLayout {
                                spacing: 6px;
                                Text {
                                    text: "إظهار الشبكة (Show Grid)";
                                    font-size: 11px;
                                    color: #94a3b8;
                                    vertical-alignment: center;
                                }
                                Rectangle {
                                    width: 32px;
                                    height: 18px;
                                    border-radius: 9px;
                                    background: root.grid-enabled ? #3b82f6 : #1e293b;
                                    
                                    Rectangle {
                                        x: root.grid-enabled ? 16px : 2px;
                                        y: 2px;
                                        width: 14px;
                                        height: 14px;
                                        border-radius: 7px;
                                        background: #ffffff;
                                    }
                                    TouchArea {
                                        clicked => { root.grid-enabled = !root.grid-enabled; }
                                    }
                                }
                            }
                        }
                    }
                }

                // Scroll view for canvas wrapping
                Rectangle {
                    vertical-stretch: 1;
                    background: #020617;
                    border-radius: 12px;
                    border-width: 1px;
                    border-color: #ffffff0d;
                    clip: true;

                    ScrollView {
                        width: 100%;
                        height: 100%;

                        // Center the canvas inside viewport
                        Rectangle {
                            width: Math.max(parent.width, canvas-container.width + 60px);
                            height: Math.max(parent.height, canvas-container.height + 60px);

                            canvas-container := Rectangle {
                                width: root.canvas-width * root.zoom-factor * 1px;
                                height: root.canvas-height * root.zoom-factor * 1px;
                                x: (parent.width - self.width) / 2;
                                y: (parent.height - self.height) / 2;

                                // The dynamic image rendered by Rust
                                Image {
                                    width: 100%;
                                    height: 100%;
                                    source: root.canvas-image;
                                    image-rendering: root.is-pixel-art ? pixelated : smooth;
                                }

                                // Native Slint grid overlay (lines)
                                if root.grid-enabled && root.is-pixel-art : Rectangle {
                                    width: 100%;
                                    height: 100%;
                                    
                                    // Vertical grid lines
                                    for i in root.canvas-width + 1 : Rectangle {
                                        x: i * (parent.width / root.canvas-width);
                                        y: 0;
                                        width: 1px;
                                        height: parent.height;
                                        background: #ffffff13;
                                    }
                                    // Horizontal grid lines
                                    for j in root.canvas-height + 1 : Rectangle {
                                        x: 0;
                                        y: j * (parent.height / root.canvas-height);
                                        width: parent.width;
                                        height: 1px;
                                        background: #ffffff13;
                                    }
                                }

                                // Interactive touch area to draw!
                                TouchArea {
                                    width: 100%;
                                    height: 100%;

                                    pointer-event(event) => {
                                        root.pointer-event(
                                            event.kind == PointerEventKind.down ? "down" : (event.kind == PointerEventKind.up ? "up" : "move"),
                                            self.mouse-x,
                                            self.mouse-y,
                                            self.width,
                                            self.height
                                        );
                                    }
                                }
                            }
                        }
                    }
                }
            }

            // --- RIGHT COLUMN: COLOR PICKER & LAYERS PANEL ---
            Rectangle {
                width: 280px;
                background: #ffffff03;
                border-radius: 12px;
                border-width: 1px;
                border-color: #ffffff0d;

                VerticalLayout {
                    padding: 14px;
                    spacing: 12px;
                    alignment: start;

                    // COLOR SECTION
                    Text {
                        text: "لوحة الألوان (Colors)";
                        font-size: 13px;
                        font-weight: 700;
                        color: #ffffff;
                        horizontal-alignment: right;
                    }

                    // A premium preset color grid
                    Rectangle {
                        height: 70px;
                        background: #ffffff02;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: #ffffff08;
                        padding: 6px;

                        GridLayout {
                            spacing: 5px;
                            
                            // Row 1
                            Row {
                                ColorPaletteButton { color-val: #000000; clicked => { root.color-r = 0.0; root.color-g = 0.0; root.color-b = 0.0; root.change-color(0, 0, 0, 255); } }
                                ColorPaletteButton { color-val: #ffffff; clicked => { root.color-r = 1.0; root.color-g = 1.0; root.color-b = 1.0; root.change-color(255, 255, 255, 255); } }
                                ColorPaletteButton { color-val: #ef4444; clicked => { root.color-r = 0.93; root.color-g = 0.27; root.color-b = 0.27; root.change-color(239, 68, 68, 255); } }
                                ColorPaletteButton { color-val: #f97316; clicked => { root.color-r = 0.97; root.color-g = 0.45; root.color-b = 0.08; root.change-color(249, 115, 22, 255); } }
                                ColorPaletteButton { color-val: #eab308; clicked => { root.color-r = 0.92; root.color-g = 0.7; root.color-b = 0.03; root.change-color(234, 179, 8, 255); } }
                                ColorPaletteButton { color-val: #22c55e; clicked => { root.color-r = 0.13; root.color-g = 0.77; root.color-b = 0.36; root.change-color(34, 197, 94, 255); } }
                                ColorPaletteButton { color-val: #06b6d4; clicked => { root.color-r = 0.02; root.color-g = 0.71; root.color-b = 0.83; root.change-color(6, 182, 212, 255); } }
                                ColorPaletteButton { color-val: #3b82f6; clicked => { root.color-r = 0.23; root.color-g = 0.51; root.color-b = 0.96; root.change-color(59, 130, 246, 255); } }
                            }
                            // Row 2
                            Row {
                                ColorPaletteButton { color-val: #8b5cf6; clicked => { root.color-r = 0.54; root.color-g = 0.36; root.color-b = 0.96; root.change-color(139, 92, 246, 255); } }
                                ColorPaletteButton { color-val: #ec4899; clicked => { root.color-r = 0.92; root.color-g = 0.28; root.color-b = 0.6; root.change-color(236, 72, 153, 255); } }
                                ColorPaletteButton { color-val: #78716c; clicked => { root.color-r = 0.47; root.color-g = 0.44; root.color-b = 0.42; root.change-color(120, 113, 108, 255); } }
                                ColorPaletteButton { color-val: #92400e; clicked => { root.color-r = 0.57; root.color-g = 0.25; root.color-b = 0.05; root.change-color(146, 64, 14, 255); } }
                                ColorPaletteButton { color-val: #15803d; clicked => { root.color-r = 0.08; root.color-g = 0.5; root.color-b = 0.24; root.change-color(21, 128, 61, 255); } }
                                ColorPaletteButton { color-val: #0369a1; clicked => { root.color-r = 0.01; root.color-g = 0.41; root.color-b = 0.63; root.change-color(3, 105, 161, 255); } }
                                ColorPaletteButton { color-val: #a855f7; clicked => { root.color-r = 0.66; root.color-g = 0.33; root.color-b = 0.97; root.change-color(168, 85, 247, 255); } }
                                ColorPaletteButton { color-val: transparent; clicked => { root.color-r = 0.0; root.color-g = 0.0; root.color-b = 0.0; root.color-a = 0.0; root.change-color(0, 0, 0, 0); } }
                            }
                        }
                    }

                    // RGB Custom Sliders
                    VerticalLayout {
                        spacing: 6px;

                        slider-r := SleekSlider {
                            label: "الأحمر (Red)";
                            value: root.color-r;
                            min: 0.0;
                            max: 1.0;
                            changed(val) => {
                                root.color-r = val;
                                root.change-color(Math.round(root.color-r * 255.0), Math.round(root.color-g * 255.0), Math.round(root.color-b * 255.0), Math.round(root.color-a * 255.0));
                            }
                        }
                        slider-g := SleekSlider {
                            label: "الأخضر (Green)";
                            value: root.color-g;
                            min: 0.0;
                            max: 1.0;
                            changed(val) => {
                                root.color-g = val;
                                root.change-color(Math.round(root.color-r * 255.0), Math.round(root.color-g * 255.0), Math.round(root.color-b * 255.0), Math.round(root.color-a * 255.0));
                            }
                        }
                        slider-b := SleekSlider {
                            label: "الأزرق (Blue)";
                            value: root.color-b;
                            min: 0.0;
                            max: 1.0;
                            changed(val) => {
                                root.color-b = val;
                                root.change-color(Math.round(root.color-r * 255.0), Math.round(root.color-g * 255.0), Math.round(root.color-b * 255.0), Math.round(root.color-a * 255.0));
                            }
                        }
                        slider-a := SleekSlider {
                            label: "الشفافية (Alpha)";
                            value: root.color-a;
                            min: 0.0;
                            max: 1.0;
                            changed(val) => {
                                root.color-a = val;
                                root.change-color(Math.round(root.color-r * 255.0), Math.round(root.color-g * 255.0), Math.round(root.color-b * 255.0), Math.round(root.color-a * 255.0));
                            }
                        }
                    }

                    // Display Preview Color Box
                    HorizontalLayout {
                        spacing: 8px;
                        Text {
                            text: "اللون الحالي (Active Color):";
                            font-size: 11px;
                            color: #94a3b8;
                            vertical-alignment: center;
                        }
                        Rectangle {
                            width: 60px;
                            height: 22px;
                            border-radius: 4px;
                            background: root.current-color;
                            border-width: 1px;
                            border-color: #ffffff2a;
                        }
                    }

                    // Horizontal Divider
                    Rectangle { height: 1px; background: #ffffff0d; }

                    // LAYERS SECTION
                    Text {
                        text: "الطبقات (Layers)";
                        font-size: 13px;
                        font-weight: 700;
                        color: #ffffff;
                        horizontal-alignment: right;
                    }

                    // Layer 2 (Top Layer - Active Layer 1)
                    Rectangle {
                        height: 48px;
                        background: root.active-layer == 1 ? #3b82f61a : #ffffff02;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: root.active-layer == 1 ? #3b82f640 : #ffffff0a;
                        
                        TouchArea { clicked => { root.active-layer = 1; root.change-active-layer(1); } }

                        HorizontalLayout {
                            padding: 8px;
                            spacing: 8px;
                            alignment: space-between;

                            HorizontalLayout {
                                spacing: 8px;
                                alignment: start;
                                
                                // Visibility Eye
                                Rectangle {
                                    width: 24px;
                                    height: 24px;
                                    background: root.layer2-visible ? #3b82f620 : #ffffff05;
                                    border-radius: 4px;
                                    
                                    TouchArea {
                                        clicked => {
                                            root.layer2-visible = !root.layer2-visible;
                                            root.toggle-layer-visibility(1, root.layer2-visible);
                                        }
                                    }
                                    Text {
                                        text: root.layer2-visible ? "👁️" : "❌";
                                        font-size: 11px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                Text {
                                    text: "طبقة الرسم (Draw Layer)";
                                    font-size: 12px;
                                    color: #f1f5f9;
                                    font-weight: root.active-layer == 1 ? 700 : 500;
                                    vertical-alignment: center;
                                }
                            }

                            // Layer 2 Opacity slider
                            l2-slider := SleekSlider {
                                width: 70px;
                                value: root.layer2-opacity;
                                min: 0.0;
                                max: 1.0;
                                changed(val) => {
                                    root.layer2-opacity = val;
                                    root.change-layer-opacity(1, val);
                                }
                            }
                        }
                    }

                    // Layer 1 (Bottom Layer - Active Layer 0)
                    Rectangle {
                        height: 48px;
                        background: root.active-layer == 0 ? #3b82f61a : #ffffff02;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: root.active-layer == 0 ? #3b82f640 : #ffffff0a;
                        
                        TouchArea { clicked => { root.active-layer = 0; root.change-active-layer(0); } }

                        HorizontalLayout {
                            padding: 8px;
                            spacing: 8px;
                            alignment: space-between;

                            HorizontalLayout {
                                spacing: 8px;
                                alignment: start;
                                
                                // Visibility Eye
                                Rectangle {
                                    width: 24px;
                                    height: 24px;
                                    background: root.layer1-visible ? #3b82f620 : #ffffff05;
                                    border-radius: 4px;
                                    
                                    TouchArea {
                                        clicked => {
                                            root.layer1-visible = !root.layer1-visible;
                                            root.toggle-layer-visibility(0, root.layer1-visible);
                                        }
                                    }
                                    Text {
                                        text: root.layer1-visible ? "👁️" : "❌";
                                        font-size: 11px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                Text {
                                    text: "الخلفية (Background Layer)";
                                    font-size: 12px;
                                    color: #f1f5f9;
                                    font-weight: root.active-layer == 0 ? 700 : 500;
                                    vertical-alignment: center;
                                }
                            }

                            // Layer 1 Opacity slider
                            l1-slider := SleekSlider {
                                width: 70px;
                                value: root.layer1-opacity;
                                min: 0.0;
                                max: 1.0;
                                changed(val) => {
                                    root.layer1-opacity = val;
                                    root.change-layer-opacity(0, val);
                                }
                            }
                        }
                    }

                    // Horizontal Divider
                    Rectangle { height: 1px; background: #ffffff0d; }

                    // CANVAS SIZE SECTION
                    Text {
                        text: "حجم اللوحة (Canvas Size)";
                        font-size: 12px;
                        font-weight: 700;
                        color: #ffffff;
                        horizontal-alignment: right;
                    }

                    // Canvas Resolution buttons
                    GridLayout {
                        spacing: 4px;
                        Row {
                            size-btn-16 := Rectangle {
                                height: 26px;
                                background: root.size-index == 0 ? #3b82f625 : #ffffff03;
                                border-radius: 4px;
                                border-width: 1px;
                                border-color: root.size-index == 0 ? #3b82f6 : #ffffff0a;
                                TouchArea { clicked => { root.size-index = 0; root.resize-canvas(0); } }
                                Text { text: "16x16"; font-size: 10px; color: #ffffff; horizontal-alignment: center; vertical-alignment: center; }
                            }
                            size-btn-32 := Rectangle {
                                height: 26px;
                                background: root.size-index == 1 ? #3b82f625 : #ffffff03;
                                border-radius: 4px;
                                border-width: 1px;
                                border-color: root.size-index == 1 ? #3b82f6 : #ffffff0a;
                                TouchArea { clicked => { root.size-index = 1; root.resize-canvas(1); } }
                                Text { text: "32x32"; font-size: 10px; color: #ffffff; horizontal-alignment: center; vertical-alignment: center; }
                            }
                            size-btn-64 := Rectangle {
                                height: 26px;
                                background: root.size-index == 2 ? #3b82f625 : #ffffff03;
                                border-radius: 4px;
                                border-width: 1px;
                                border-color: root.size-index == 2 ? #3b82f6 : #ffffff0a;
                                TouchArea { clicked => { root.size-index = 2; root.resize-canvas(2); } }
                                Text { text: "64x64"; font-size: 10px; color: #ffffff; horizontal-alignment: center; vertical-alignment: center; }
                            }
                        }
                        Row {
                            size-btn-128 := Rectangle {
                                height: 26px;
                                background: root.size-index == 3 ? #3b82f625 : #ffffff03;
                                border-radius: 4px;
                                border-width: 1px;
                                border-color: root.size-index == 3 ? #3b82f6 : #ffffff0a;
                                TouchArea { clicked => { root.size-index = 3; root.resize-canvas(3); } }
                                Text { text: "128x128"; font-size: 10px; color: #ffffff; horizontal-alignment: center; vertical-alignment: center; }
                            }
                            size-btn-256 := Rectangle {
                                height: 26px;
                                background: root.size-index == 4 ? #3b82f625 : #ffffff03;
                                border-radius: 4px;
                                border-width: 1px;
                                border-color: root.size-index == 4 ? #3b82f6 : #ffffff0a;
                                TouchArea { clicked => { root.size-index = 4; root.resize-canvas(4); } }
                                Text { text: "256x256"; font-size: 10px; color: #ffffff; horizontal-alignment: center; vertical-alignment: center; }
                            }
                            size-btn-512 := Rectangle {
                                height: 26px;
                                background: root.size-index == 5 ? #3b82f625 : #ffffff03;
                                border-radius: 4px;
                                border-width: 1px;
                                border-color: root.size-index == 5 ? #3b82f6 : #ffffff0a;
                                TouchArea { clicked => { root.size-index = 5; root.resize-canvas(5); } }
                                Text { text: "512x512"; font-size: 10px; color: #ffffff; horizontal-alignment: center; vertical-alignment: center; }
                            }
                        }
                    }
                }
            }
        }

        // 3. BOTTOM STATUS BAR
        Rectangle {
            height: 28px;
            background: #ffffff02;
            border-radius: 6px;
            border-width: 1px;
            border-color: #ffffff0a;

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                alignment: space-between;

                // Left side: Coordinates
                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;
                    Text {
                        text: (root.cursor-x >= 0 && root.cursor-y >= 0) ? ("الموقع: X: " + root.cursor-x + " , Y: " + root.cursor-y) : "خارج اللوحة";
                        font-size: 11px;
                        color: #94a3b8;
                        vertical-alignment: center;
                    }
                }

                // Middle: Canvas dimensions
                HorizontalLayout {
                    spacing: 8px;
                    alignment: center;
                    Text {
                        text: "حجم الصورة: " + root.canvas-width + " × " + root.canvas-height + " بكسل";
                        font-size: 11px;
                        color: #94a3b8;
                        vertical-alignment: center;
                    }
                }

                // Right side: Active status / Tool info
                HorizontalLayout {
                    spacing: 8px;
                    alignment: end;
                    Text {
                        text: "الحالة: " + root.status-text;
                        font-size: 11px;
                        color: #10b981;
                        font-weight: 700;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}
