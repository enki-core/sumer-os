export global StoreColors {
    in-out property <color> background: #0b0f19;
    in-out property <color> surface: #111827;
    in-out property <color> border: #1f2937;
    in-out property <color> border-hover: #374151;
    in-out property <color> text: #ffffff;
    in-out property <color> text-muted: #9ca3af;
    in-out property <color> text-accent: #38bdf8;
    in-out property <color> brand: #3b82f6;
    in-out property <color> success: #10b981;
    in-out property <color> warning: #f59e0b;
    in-out property <color> danger: #ef4444;
}
