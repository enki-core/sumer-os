import { Button, ScrollView } from "std-widgets.slint";
import { AppInfo } from "../data/types.slint";
import { AppCard } from "../components/app_card.slint";
import { StoreColors } from "../theme/colors.slint";
import { StoreTypography } from "../theme/typography.slint";
import { StoreSpacing } from "../theme/spacing.slint";

export component HomeView inherits ScrollView {
    in property <[AppInfo]> apps;
    in property <length> parent_width;
    
    // Callbacks to communicate events
    callback launch_app(string);
    callback install_app(int);
    callback update_app(int);
    callback show_detail(int); // index
    
    padding: StoreSpacing.padding-xl;
    
    VerticalLayout {
        spacing: StoreSpacing.space-xxl;
        alignment: start;
        
        // A. SECTION TITLE: BUILT-IN SYSTEM APPS
        Text { 
            text: "🛠️ تطبيقات سومر المدمجة (أدوات النظام)"; 
            font-size: StoreTypography.font-size-base; 
            font-weight: StoreTypography.font-weight-bold; 
            color: StoreColors.text; 
        }
        
        // Display System Apps Cards
        HorizontalLayout {
            spacing: StoreSpacing.space-lg;
            
            for app_idx in [0, 1, 2] : Rectangle {
                width: root.parent_width / 3 - 90px;
                
                AppCard {
                    width: 100%;
                    info: root.apps[app_idx];
                    index: app_idx;
                    clicked => { root.show_detail(app-idx); }
                    action_triggered(idx) => {
                        if root.apps[idx].status == "installed" {
                            root.launch_app(root.apps[idx].id);
                        } else if root.apps[idx].status == "update_available" {
                            root.update_app(idx);
                        } else {
                            root.install_app(idx);
                        }
                    }
                }
            }
        }
        
        // C. SECTION TITLE: EXTERNAL DESKTOP APPS
        Text { 
            text: "🌐 برمجيات سطح المكتب الخارجية"; 
            font-size: StoreTypography.font-size-base; 
            font-weight: StoreTypography.font-weight-bold; 
            color: StoreColors.text; 
        }
        
        // Display External Popular Apps Cards
        HorizontalLayout {
            spacing: StoreSpacing.space-lg;
            
            for app_idx in [4, 5, 6] : Rectangle {
                width: root.parent_width / 3 - 90px;
                
                AppCard {
                    width: 100%;
                    info: root.apps[app_idx];
                    index: app_idx;
                    clicked => { root.show_detail(app-idx); }
                    action_triggered(idx) => {
                        if root.apps[idx].status == "installed" {
                            root.launch_app(root.apps[idx].id);
                        } else if root.apps[idx].status == "update_available" {
                            root.update_app(idx);
                        } else {
                            root.install_app(idx);
                        }
                    }
                }
            }
        }
    }
}
