import { Palette } from "std-widgets.slint";
import { CalcButton } from "components/calc_button.slint";
import { MenuPopup } from "components/menu.slint";
import { CalcDisplay } from "components/display.slint";
import { HistoryOverlay } from "components/history.slint";

export component App inherits Window {
    // English window title solves the reversed Arabic RTL rendering glitch in the OS title bar!
    title: "Enki Calc";
    width: 420px;
    height: 780px;
    background: @linear-gradient(135deg, #020617 0%, #0b1329 50%, #1e1b4b 100%);
    
    in-out property <string> expression: "";
    in-out property <string> result: "0";
    in-out property <string> syntax-error: "";
    in-out property <[string]> history_list: [];
    in-out property <bool> show_history: false;
    in-out property <bool> mini_mode: false;
    in-out property <bool> glass_effects: true;
    
    callback button_pressed(string);
    callback calculate();
    callback clear();
    callback backspace();
    callback toggle_mini_mode();
    callback toggle_history();
    callback clear_history();

    // Responsive Menu Dropdown
    popup := PopupWindow {
        x: 20px;
        y: 60px;
        width: 240px;
        MenuPopup {
            mini_mode_clicked => { root.toggle_mini_mode(); popup.close(); }
            history_clicked => { root.toggle_history(); popup.close(); }
            glass_clicked => { root.glass_effects = !root.glass_effects; popup.close(); }
            steps_clicked => { popup.close(); root.syntax-error = "وضع الحل بالخطوات قيد التطوير (بيتا)!"; }
            solver_clicked => { popup.close(); root.syntax-error = "وضع حل المعادلات قيد التطوير (بيتا)!"; }
        }
    }

    VerticalLayout {
        padding: 24px;
        spacing: 16px;

        // Top Bar
        HorizontalLayout {
            height: 35px;
            TouchArea {
                width: 40px;
                clicked => { popup.show(); }
                Text { text: "⋮"; font-size: 28px; color: white; font-weight: 700; vertical-alignment: center; }
            }
            Rectangle { horizontal-stretch: 1; }
            Text { 
                text: root.mini_mode ? "Enki Mini" : "حاسبة إنكي العظيمة"; 
                color: #38bdf8; 
                font-size: 16px; 
                font-weight: 700;
                vertical-alignment: center; 
            }
        }

        // Responsive Glassmorphic Error Banner
        if root.syntax-error != "" : Rectangle {
            height: 35px;
            background: #ef444425;
            border-radius: 8px;
            border-width: 1px;
            border-color: #ef444440;
            Text { text: root.syntax-error; color: #fca5a5; font-size: 13px; font-weight: 500; horizontal-alignment: center; vertical-alignment: center; }
        }

        // Proportional Glassmorphic Display (Responsive height)
        CalcDisplay {
            expression: root.expression;
            result: root.result;
            mini_mode: root.mini_mode;
            vertical-stretch: 1;
        }

        // History overlay overlay
        if root.show_history : HistoryOverlay {
            history_list: root.history_list;
            vertical-stretch: 3;
            item_clicked(item) => { 
                // Restore expression
                root.expression = item; 
                root.show_history = false; 
            }
            close_clicked => { root.show_history = false; }
        }

        // Responsive Keypad (Vertical stretch automatically fits window size)
        if !root.show_history : VerticalLayout {
            spacing: 12px;
            vertical-stretch: 3;

            // Advanced Scientific Row 1 (Trig)
            if !root.mini_mode : HorizontalLayout {
                height: 45px;
                spacing: 8px;
                CalcButton { text: "sin"; font-size: 14px; base-color: root.glass_effects ? #ffffff05 : #0b1329; clicked => { root.button_pressed("sin("); } }
                CalcButton { text: "cos"; font-size: 14px; base-color: root.glass_effects ? #ffffff05 : #0b1329; clicked => { root.button_pressed("cos("); } }
                CalcButton { text: "tan"; font-size: 14px; base-color: root.glass_effects ? #ffffff05 : #0b1329; clicked => { root.button_pressed("tan("); } }
                CalcButton { text: "sec"; font-size: 14px; base-color: root.glass_effects ? #ffffff05 : #0b1329; clicked => { root.button_pressed("sec("); } }
                CalcButton { text: "csc"; font-size: 14px; base-color: root.glass_effects ? #ffffff05 : #0b1329; clicked => { root.button_pressed("csc("); } }
                CalcButton { text: "cot"; font-size: 14px; base-color: root.glass_effects ? #ffffff05 : #0b1329; clicked => { root.button_pressed("cot("); } }
            }

            // Advanced Scientific Row 2 (Vars & Complex)
            if !root.mini_mode : HorizontalLayout {
                height: 45px;
                spacing: 8px;
                CalcButton { text: "pi";  font-size: 14px; base-color: root.glass_effects ? #ffffff05 : #0b1329; clicked => { root.button_pressed("pi"); } }
                CalcButton { text: "√";   font-size: 16px; base-color: root.glass_effects ? #ffffff05 : #0b1329; clicked => { root.button_pressed("sqrt("); } }
                CalcButton { text: "^";   font-size: 16px; base-color: root.glass_effects ? #ffffff05 : #0b1329; clicked => { root.button_pressed("^"); } }
                CalcButton { text: "x";   font-size: 18px; text-color: #6ee7b7; base-color: root.glass_effects ? #ffffff05 : #0b1329; clicked => { root.button_pressed("x"); } }
                CalcButton { text: "y";   font-size: 18px; text-color: #6ee7b7; base-color: root.glass_effects ? #ffffff05 : #0b1329; clicked => { root.button_pressed("y"); } }
            }

            // Keypad Grid
            GridLayout {
                spacing: 12px;
                
                Row {
                    CalcButton { text: "C"; text-color: #ef4444; base-color: #ef444415; clicked => { root.clear(); } }
                    CalcButton { text: "()"; text-color: #38bdf8; base-color: root.glass_effects ? #ffffff08 : #0b1329; clicked => { root.button_pressed("()"); } }
                    CalcButton { text: "⌫"; text-color: #f59e0b; base-color: #f59e0b15; clicked => { root.backspace(); } }
                    CalcButton { text: "÷"; is-operator: true; text-color: #a855f7; base-color: #a855f715; clicked => { root.button_pressed("/"); } }
                }
                Row {
                    CalcButton { text: "7"; base-color: root.glass_effects ? #ffffff08 : #0b1329; clicked => { root.button_pressed("7"); } }
                    CalcButton { text: "8"; base-color: root.glass_effects ? #ffffff08 : #0b1329; clicked => { root.button_pressed("8"); } }
                    CalcButton { text: "9"; base-color: root.glass_effects ? #ffffff08 : #0b1329; clicked => { root.button_pressed("9"); } }
                    CalcButton { text: "×"; is-operator: true; text-color: #a855f7; base-color: #a855f715; clicked => { root.button_pressed("*"); } }
                }
                Row {
                    CalcButton { text: "4"; base-color: root.glass_effects ? #ffffff08 : #0b1329; clicked => { root.button_pressed("4"); } }
                    CalcButton { text: "5"; base-color: root.glass_effects ? #ffffff08 : #0b1329; clicked => { root.button_pressed("5"); } }
                    CalcButton { text: "6"; base-color: root.glass_effects ? #ffffff08 : #0b1329; clicked => { root.button_pressed("6"); } }
                    CalcButton { text: "-"; is-operator: true; text-color: #a855f7; base-color: #a855f715; clicked => { root.button_pressed("-"); } }
                }
                Row {
                    CalcButton { text: "1"; base-color: root.glass_effects ? #ffffff08 : #0b1329; clicked => { root.button_pressed("1"); } }
                    CalcButton { text: "2"; base-color: root.glass_effects ? #ffffff08 : #0b1329; clicked => { root.button_pressed("2"); } }
                    CalcButton { text: "3"; base-color: root.glass_effects ? #ffffff08 : #0b1329; clicked => { root.button_pressed("3"); } }
                    CalcButton { text: "+"; is-operator: true; text-color: #a855f7; base-color: #a855f715; clicked => { root.button_pressed("+"); } }
                }
                Row {
                    CalcButton { text: "0"; base-color: root.glass_effects ? #ffffff08 : #0b1329; clicked => { root.button_pressed("0"); } }
                    CalcButton { text: "."; base-color: root.glass_effects ? #ffffff08 : #0b1329; clicked => { root.button_pressed("."); } }
                    CalcButton { text: "="; is-operator: true; text-color: #ffffff; base-color: #6366f1; colspan: 2; clicked => { root.calculate(); } }
                }
            }
        }
    }
}
