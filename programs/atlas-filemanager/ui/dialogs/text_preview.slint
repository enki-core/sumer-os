import { Button, ScrollView } from "std-widgets.slint";

export component TextPreviewDialog inherits Rectangle {
    in property <string> file-name;
    in property <string> text-content;
    callback close;

    width: 100%;
    height: 100%;
    background: #000000d0;

    TouchArea {
        clicked => { root.close(); }
    }

    Rectangle {
        width: 700px;
        height: 480px;
        background: #0d1527fa;
        border-radius: 20px;
        border-width: 1px;
        border-color: #3b82f640;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;

        // Intercept clicks on the dialog itself to prevent closing
        TouchArea {}

        VerticalLayout {
            padding: 16px;
            spacing: 12px;

            // Preview Header
            HorizontalLayout {
                alignment: space-between;
                
                // Close button
                Rectangle {
                    width: 28px;
                    height: 28px;
                    border-radius: 14px;
                    background: #ef444420;
                    border-width: 1px;
                    border-color: #ef444450;
                    Text { text: "✕"; color: #ef4444; horizontal-alignment: center; vertical-alignment: center; }
                    TouchArea { clicked => { root.close(); } }
                }

                Text {
                    text: file-name + " — معاينة سريعة 👁️";
                    font-size: 14px;
                    font-weight: 700;
                    color: #ffffff;
                    vertical-alignment: center;
                }
            }

            // Text Viewer area
            Rectangle {
                horizontal-stretch: 1;
                vertical-stretch: 1;
                background: #050811e5;
                border-radius: 10px;
                border-width: 1px;
                border-color: #ffffff10;
                padding: 12px;

                ScrollView {
                    width: 100%;
                    height: 100%;
                    Text {
                        width: parent.viewport-width;
                        text: text-content;
                        font-size: 13px;
                        color: #cbd5e1;
                        font-family: "monospace";
                        wrap: word-wrap;
                        horizontal-alignment: right; // Arabic text preview support
                    }
                }
            }

            // Actions footer
            HorizontalLayout {
                alignment: end;
                Button {
                    text: "إغلاق المعاينة";
                    clicked => { root.close(); }
                }
            }
        }
    }
}
