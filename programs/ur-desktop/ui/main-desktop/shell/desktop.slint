import { SumerStartMenu } from "./start-menu.slint";
import { SumerTaskbar } from "./taskbar.slint";
import { SumerDesktopBackground } from "../desktop-layers/desktop-background.slint";
import { SumerDesktopHeader } from "../desktop-layers/desktop-header.slint";
import { SumerDesktopIconsLayer } from "../desktop-layers/desktop-icons-layer.slint";
import { SumerDesktopWindowsLayer } from "../desktop-layers/desktop-windows-layer.slint";
import { SumerControlCenter } from "./control-center.slint";
import { SumerSystemTray } from "./system-tray.slint";
import { SumerDesktopIcon } from "../components/desktop-icon.slint";
import { WallpapersApp } from "../apps/wallpapers-app.slint";
import { WidgetsMenu } from "../apps/widgets-menu.slint";
import { AppIcon } from "../core/models.slint";

export component SumerDesktop inherits Rectangle {
    in property <bool> dark-mode: true;
    in property <string> current-time: "12:00 PM";
    
    in-out property <int> wallpaper-index: -1;
    
    // Keyboard navigation index for desktop shortcuts (0 = Files, 1 = Console, 2 = TV)
    in-out property <int> focused-index: 0;
    in-out property <int> active-glow-index: 0;
    
    in-out property <[AppIcon]> dock-icons: [
        { id: "files", name: "مدير الملفات", icon: "📁", bg_color: #3b82f6, hover_bg_color: #2563eb },
        { id: "console", name: "شيل دجلة", icon: "💻", bg_color: #10b981, hover_bg_color: #059669 },
        { id: "tv", name: "أندرويد تي في", icon: "📺", bg_color: #f97316, hover_bg_color: #ea580c },
        { id: "wallpapers", name: "الخلفيات", icon: "🎨", bg_color: #8b5cf6, hover_bg_color: #7c3aed },
        { id: "shortcuts", name: "الاختصارات", icon: "⌨️", bg_color: #64748b, hover_bg_color: #475569 }
    ];
    
    // Windows and overlays open states
    in-out property <bool> start-menu-open: false;
    in-out property <bool> files-window-open: false;
    in-out property <bool> console-window-open: false;
    in-out property <bool> control-center-open: false;
    in-out property <bool> wallpapers-window-open: false;
    in-out property <bool> notes-window-open: false;
    in-out property <bool> clock-window-open: false;
    in-out property <bool> widgets-menu-open: false;
    in-out property <bool> shortcuts-window-open: false;
    
    property <float> menu-opacity: root.start-menu-open ? 1.0 : 0.0;
    property <length> menu-offset: root.start-menu-open ? 0px : 20px;
    
    animate menu-opacity { duration: 220ms; easing: ease-out; }
    animate menu-offset { duration: 220ms; easing: ease-out; }
    
    in-out property <bool> is-any-window-fullscreen: false;
    
    // Drag and Drop Global State
    in-out property <bool> is-dragging-icon: false;
    in-out property <AppIcon> dragged-icon;
    in-out property <length> drag-x;
    
    in-out property <length> drag-y;
    
    in-out property <bool> show-desktop-files: true;
    in-out property <bool> show-desktop-console: true;
    in-out property <bool> show-desktop-tv: true;
    
    in-out property <bool> show-dock-files: true;
    in-out property <bool> show-dock-console: true;
    in-out property <bool> show-dock-tv: true;
    
    in-out property <length> desktop-icon0-x: 24px;
    in-out property <length> desktop-icon0-y: 80px;
    in-out property <length> desktop-icon1-x: 24px;
    in-out property <length> desktop-icon1-y: 200px;
    in-out property <length> desktop-icon2-x: 24px;
    in-out property <length> desktop-icon2-y: 320px;
    
    // System Tray properties (Issue #11)
    in-out property <string> battery-status: "🔋 98%";
    in-out property <string> network-status: "📶";
    callback update-system-status(string, string, string);
    
    // Control Center properties & callbacks (Issue #12)
    in-out property <bool> wifi-on: true;
    in-out property <bool> bt-on: true;
    in-out property <bool> airplane-on: false;
    in-out property <float> brightness: 0.9;
    in-out property <float> volume: 0.8;
    
    callback brightness-changed(float);
    callback volume-changed(float);
    callback wifi-toggled(bool);
    callback bluetooth-toggled(bool);
    callback airplane-toggled(bool);
    
    callback launch-tv;
    callback app-clicked(string);
    callback icon-drag-started(int, length, length);
    callback icon-drag-moved(int, length, length);
    callback icon-drag-ended(int, length, length);
    callback desktop-icon-dropped-in-dock(string);
    callback select-app-index(string);
    callback execute-console-command(string) -> string;
    
    select-app-index(id) => {
        if (id == "files") { root.focused-index = 0; }
        else if (id == "console") { root.focused-index = 1; }
        else if (id == "tv") { root.focused-index = 2; }
    }
    
    width: 100%;
    height: 100%;
    
    // Capture global keyboard shortcuts
    fs := FocusScope {
        init => { self.focus(); }
        key-pressed(event) => {
            if (event.text == Key.Escape) {
                root.start-menu-open = false;
                root.control-center-open = false;
                return accept;
            }
            if (event.text == Key.UpArrow || event.text == Key.LeftArrow) {
                root.focused-index = Math.mod(root.focused-index - 1 + 3, 3);
                return accept;
            }
            if (event.text == Key.DownArrow || event.text == Key.RightArrow) {
                root.focused-index = Math.mod(root.focused-index + 1, 3);
                return accept;
            }
            if (event.text == Key.Return || event.text == " ") {
                if (root.focused-index == 0) { root.files-window-open = true; }
                else if (root.focused-index == 1) { root.console-window-open = true; }
                else if (root.focused-index == 2) { root.launch-tv(); }
                return accept;
            }
            return reject;
        }
    }
    
    SumerDesktopBackground {
        dark-mode: root.dark-mode;
        active-glow-index: root.active-glow-index;
        wallpaper-index: root.wallpaper-index;
        clicked => { 
            root.start-menu-open = false; 
            root.control-center-open = false;
        }
    }
    
    SumerDesktopHeader {
        dark-mode: root.dark-mode;
        visible: !root.is-any-window-fullscreen;
    }
    
    desktop-icons := SumerDesktopIconsLayer {
        dark-mode: root.dark-mode;
        focused-index: root.focused-index;
        app-models: root.dock-icons;
        
        show-files <=> root.show-desktop-files;
        show-console <=> root.show-desktop-console;
        show-tv <=> root.show-desktop-tv;
        icon0-x <=> root.desktop-icon0-x;
        icon0-y <=> root.desktop-icon0-y;
        icon1-x <=> root.desktop-icon1-x;
        icon1-y <=> root.desktop-icon1-y;
        icon2-x <=> root.desktop-icon2-x;
        icon2-y <=> root.desktop-icon2-y;
        dropped-in-dock(id) => { root.desktop-icon-dropped-in-dock(id); }
        
        open-files => { root.files-window-open = true; root.select-app-index("files"); }
        open-console => { root.console-window-open = true; root.select-app-index("console"); }
        launch-tv => { root.launch-tv(); root.select-app-index("tv"); }
        open-shortcuts => { root.shortcuts-window-open = true; }
    }
    
    SumerDesktopWindowsLayer {
        dark-mode: root.dark-mode;
        files-window-open: root.files-window-open;
        console-window-open: root.console-window-open;
        wallpapers-window-open: root.wallpapers-window-open;
        notes-window-open: root.notes-window-open;
        clock-window-open: root.clock-window-open;
        shortcuts-window-open: root.shortcuts-window-open;
        has-fullscreen-window <=> root.is-any-window-fullscreen;
        
        close-files => { root.files-window-open = false; }
        close-console => { root.console-window-open = false; }
        close-wallpapers => { root.wallpapers-window-open = false; }
        close-notes => { root.notes-window-open = false; }
        close-clock => { root.clock-window-open = false; }
        close-shortcuts => { root.shortcuts-window-open = false; }
        wallpaper-selected(idx) => { root.wallpaper-index = idx; }
        clear-wallpaper => { root.wallpaper-index = -1; }
        execute-console-command(cmd) => { root.execute-console-command(cmd) }
    }
    
    SumerStartMenu {
        dark-mode: root.dark-mode;
        app-models: root.dock-icons;
        x: (root.width - 320px) / 2;
        y: root.height - 420px - 70px + root.menu-offset;
        opacity: root.menu-opacity;
        visible: root.menu-opacity > 0.05;
        
        files-clicked => {
            root.files-window-open = true;
            root.start-menu-open = false;
        }
        console-clicked => {
            root.console-window-open = true;
            root.start-menu-open = false;
        }
        tv-clicked => {
            root.launch-tv();
            root.start-menu-open = false;
        }
        settings-clicked => {
            root.app-clicked("Settings");
            root.start-menu-open = false;
        }
        shutdown-clicked => {
            root.app-clicked("Shutdown");
            root.start-menu-open = false;
        }
    }
    
    if (root.control-center-open) : SumerControlCenter {
        dark-mode: root.dark-mode;
        x: parent.width - self.width - 24px;
        y: 80px; // Drops down from the top right pill
        wifi-on <=> root.wifi-on;
        bt-on <=> root.bt-on;
        airplane-on <=> root.airplane-on;
        brightness <=> root.brightness;
        volume <=> root.volume;
        toggle-dark-mode => { root.app-clicked("Toggle Theme"); }
        brightness-changed(val) => { root.brightness-changed(val); }
        volume-changed(val) => { root.volume-changed(val); }
        wifi-toggled(val) => { root.wifi-toggled(val); }
        bluetooth-toggled(val) => { root.bluetooth-toggled(val); }
        airplane-toggled(val) => { root.airplane-toggled(val); }
    }
    
    SumerSystemTray {
        x: parent.width - self.width - 24px;
        y: 24px;
        current-time: root.current-time;
        battery-status: root.battery-status;
        network-status: root.network-status;
        dark-mode: root.dark-mode;
        control-center-open: root.control-center-open;
        visible: !root.is-any-window-fullscreen;
        control-center-clicked => {
            root.control-center-open = !root.control-center-open;
            root.start-menu-open = false;
            root.widgets-menu-open = false;
        }
    }

    // Widgets Button
    Rectangle {
        x: parent.width - 210px - 24px - 48px - 12px; // 210px is SumerSystemTray width
        y: 24px;
        width: 48px;
        height: 42px;
        border-radius: 21px;
        visible: !root.is-any-window-fullscreen;
        background: root.widgets-menu-open ? (root.dark-mode ? #38bdf830 : #0284c725) : 
                    (widgets-touch.has-hover ? (root.dark-mode ? #ffffff15 : #00000010) :
                    (root.dark-mode ? #0f172ae5 : #f8fafce5));
        border-width: 1px;
        border-color: root.widgets-menu-open ? (root.dark-mode ? #38bdf8a0 : #0284c7a0) : 
                      (root.dark-mode ? #ffffff1a : #00000015);
        animate background, border-color { duration: 150ms; }
        
        Text {
            text: "🧩";
            font-size: 18px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
        
        widgets-touch := TouchArea {
            clicked => {
                root.widgets-menu-open = !root.widgets-menu-open;
                root.control-center-open = false;
                root.start-menu-open = false;
            }
        }
    }
    
    // Widgets Menu
    if (root.widgets-menu-open) : WidgetsMenu {
        x: parent.width - 210px - 24px - 48px - 12px;
        y: 70px; // Just below the button
        dark-mode: root.dark-mode;
        notes-clicked => {
            root.notes-window-open = true;
            root.widgets-menu-open = false;
        }
        clock-clicked => {
            root.clock-window-open = true;
            root.widgets-menu-open = false;
        }
    }
    
    taskbar := SumerTaskbar { // Now acts as a floating Dock
        x: (parent.width - self.width) / 2;
        y: parent.height - self.height - 24px;
        dark-mode: root.dark-mode;
        visible: !root.is-any-window-fullscreen;
        
        start-menu-open: root.start-menu-open;
        icons: root.dock-icons;
        show-dock-files: root.show-dock-files;
        show-dock-console: root.show-dock-console;
        show-dock-tv: root.show-dock-tv;
        drag-over: (desktop-icons.active-drag-index != -1 && (
            desktop-icons.active-drag-index == 0 ? desktop-icons.icon0-y > root.height - 250px :
            desktop-icons.active-drag-index == 1 ? desktop-icons.icon1-y > root.height - 250px :
            desktop-icons.icon2-y > root.height - 250px
        )) || (root.is-dragging-icon && root.drag-y > root.height - 250px);
        active-drag-index: desktop-icons.active-drag-index;
        target-index: desktop-icons.active-drag-index != -1 ? (
            ((desktop-icons.active-drag-index == 0 ? desktop-icons.icon0-x :
              desktop-icons.active-drag-index == 1 ? desktop-icons.icon1-x : desktop-icons.icon2-x) - root.width / 2) < -114px ? 0 :
            ((desktop-icons.active-drag-index == 0 ? desktop-icons.icon0-x :
              desktop-icons.active-drag-index == 1 ? desktop-icons.icon1-x : desktop-icons.icon2-x) - root.width / 2) < -38px ? 1 :
            ((desktop-icons.active-drag-index == 0 ? desktop-icons.icon0-x :
              desktop-icons.active-drag-index == 1 ? desktop-icons.icon1-x : desktop-icons.icon2-x) - root.width / 2) < 38px ? 2 :
            ((desktop-icons.active-drag-index == 0 ? desktop-icons.icon0-x :
              desktop-icons.active-drag-index == 1 ? desktop-icons.icon1-x : desktop-icons.icon2-x) - root.width / 2) < 114px ? 3 : 4
        ) : (root.is-dragging-icon ? (
            (root.drag-x - root.width / 2) < -114px ? 0 :
            (root.drag-x - root.width / 2) < -38px ? 1 :
            (root.drag-x - root.width / 2) < 38px ? 2 :
            (root.drag-x - root.width / 2) < 114px ? 3 : 4
        ) : -1);
        
        start-clicked => { 
            root.start-menu-open = !root.start-menu-open; 
            root.control-center-open = false;
        }
        item-clicked(id) => {
            if (id == "files") { root.files-window-open = !root.files-window-open; }
            else if (id == "console") { root.console-window-open = !root.console-window-open; }
            else if (id == "tv") { root.launch-tv(); }
            else if (id == "wallpapers") { root.wallpapers-window-open = !root.wallpapers-window-open; }
            else if (id == "shortcuts") { root.shortcuts-window-open = !root.shortcuts-window-open; }
        }
        item-drag-started(idx, mx, my) => { root.icon-drag-started(idx, mx, my); }
        item-dragged(idx, mx, my) => { root.icon-drag-moved(idx, mx, my); }
        item-dropped(idx, mx, my) => { root.icon-drag-ended(idx, mx, my); }
    }
    
    // Global Drag & Drop Overlay (Always rendered on top)
    if (root.is-dragging-icon) : Rectangle {
        x: root.drag-x - 32px; // Center the icon on the mouse pointer
        y: root.drag-y - 32px;
        width: 64px; height: 64px; border-radius: 16px;
        background: root.dragged-icon.bg-color;
        drop-shadow-color: root.dark-mode ? #00000080 : #00000040;
        drop-shadow-blur: 20px;
        drop-shadow-offset-y: 10px;
        
        Text { 
            text: root.dragged-icon.icon; 
            font-size: 32px; 
            horizontal-alignment: center; 
            vertical-alignment: center; 
        }
    }
    
    // Desktop Drag Proxy Layer (Renders desktop icons on top of everything including taskbar and windows)
    if (desktop-icons.active-drag-index != -1) : SumerDesktopIcon {
        x: desktop-icons.active-drag-index == 0 ? desktop-icons.icon0-x :
           desktop-icons.active-drag-index == 1 ? desktop-icons.icon1-x : desktop-icons.icon2-x;
        y: desktop-icons.active-drag-index == 0 ? desktop-icons.icon0-y :
           desktop-icons.active-drag-index == 1 ? desktop-icons.icon1-y : desktop-icons.icon2-y;
        text: root.dock-icons[desktop-icons.active-drag-index].name;
        icon: root.dock-icons[desktop-icons.active-drag-index].icon;
        bg-color: root.dock-icons[desktop-icons.active-drag-index].bg_color;
        hover-bg-color: root.dock-icons[desktop-icons.active-drag-index].hover_bg_color;
        is-dragged: true;
        dark-mode: root.dark-mode;
    }
}
