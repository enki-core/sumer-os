export component ClockApp inherits Rectangle {
    in property <bool> dark-mode: true;
    background: root.dark-mode ? #1e293b : #ffffff;
    border-radius: 8px;
    
    VerticalLayout {
        padding: 16px;
        spacing: 12px;
        alignment: center;
        Text { text: "12:00 PM"; font-size: 48px; font-weight: 900; color: root.dark-mode ? #38bdf8 : #0284c7; horizontal-alignment: center; }
        Text { text: "العراق - بغداد"; font-size: 14px; color: root.dark-mode ? #94a3b8 : #475569; horizontal-alignment: center; }
    }
}
