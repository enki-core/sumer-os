import { SumerDesktopIcon } from "../components/desktop-icon.slint";
import { SumerDragDropMath } from "../core/drag-drop-manager.slint";
import { AppIcon } from "../core/models.slint";

export component SumerDesktopIconsLayer inherits Rectangle {
    in property <bool> dark-mode: true;
    in-out property <int> focused-index: 0;
    in property <[AppIcon]> app-models;
    
    in-out property <int> active-drag-index: -1;
    
    in-out property <length> icon0-x: 24px;
    in-out property <length> icon0-y: 80px;
    
    in-out property <length> icon1-x: 24px;
    in-out property <length> icon1-y: 200px;
    
    in-out property <length> icon2-x: 24px;
    in-out property <length> icon2-y: 320px;
    
    in-out property <length> icon3-x: 24px;
    in-out property <length> icon3-y: 440px;
    
    // Physics Momentum & Live Directional Evasion Tracking
    property <length> last_dx: 0px;
    property <length> last_dy: 0px;
    // Separate drag start properties for each icon so evasion never corrupts them!
    property <length> start_drag0_x: 24px;
    property <length> start_drag0_y: 80px;
    property <length> start_drag1_x: 24px;
    property <length> start_drag1_y: 200px;
    property <length> start_drag2_x: 24px;
    property <length> start_drag2_y: 320px;
    property <length> start_drag3_x: 24px;
    property <length> start_drag3_y: 440px;
    
    property <length> target_x: 0px;
    property <length> target_y: 0px;
    property <length> current_grid_x: 0px;
    property <length> current_grid_y: 0px;
    property <length> w_max: root.width - 114px;
    property <length> h_max: root.height - 180px;
    
    in-out property <bool> show-files: true;
    in-out property <bool> show-console: true;
    in-out property <bool> show-tv: true;
    in-out property <bool> show-shortcuts: true;
    
    callback open-files;
    callback open-console;
    callback launch-tv;
    callback open-shortcuts;
    callback dropped-in-dock(string);
    
    width: 100%;
    height: 100%;
    
    // Ultra-responsive 150ms spring physics for dragging, directional evasion leaps, throwing, and snapping!
    animate icon0-x, icon0-y, icon1-x, icon1-y, icon2-x, icon2-y, icon3-x, icon3-y {
        duration: 150ms;
        easing: ease-out;
    }
    
    if (root.show-files) : SumerDesktopIcon {
        x: root.icon0-x;
        y: root.icon0-y;
        text: root.app-models[0].name;
        icon: "📁";
        is-focused: root.focused-index == 0;
        dark-mode: root.dark-mode;
        is-dragged: root.active-drag-index == 0;
        hide-for-proxy: root.active-drag-index == 0;
        bg-color: root.app-models[0].bg_color;
        hover-bg-color: root.app-models[0].hover_bg_color;
        
        clicked => {
            root.focused-index = 0;
            root.open-files();
        }
        drag-started => { 
            root.active-drag-index = 0; 
            root.start_drag0_x = root.icon0-x;
            root.start_drag0_y = root.icon0-y;
        }
        drag-ended => {
            root.active-drag-index = -1;
            if (root.icon0-y > root.height - 250px) {
                root.icon0-x = 24px;
                root.icon0-y = 80px;
                root.dropped-in-dock("files");
            } else {
                root.target_x = SumerDragDropMath.snap-to-grid-x(root.icon0-x + (root.last_dx * 1.5), root.width);
                root.target_y = SumerDragDropMath.snap-to-grid-y(root.icon0-y + (root.last_dy * 1.5), root.height);
                
                if (root.icon1-x == root.target_x && root.icon1-y == root.target_y) {
                    root.icon1-x = root.start_drag0_x;
                    root.icon1-y = root.start_drag0_y;
                }
                if (root.icon2-x == root.target_x && root.icon2-y == root.target_y) {
                    root.icon2-x = root.start_drag0_x;
                    root.icon2-y = root.start_drag0_y;
                }
                
                root.icon0-x = root.target_x;
                root.icon0-y = root.target_y;
            }
            root.last_dx = 0px;
            root.last_dy = 0px;
        }
        dragged-by(dx, dy) => {
            root.last_dx = dx;
            root.last_dy = dy;
            root.icon0-x = SumerDragDropMath.bound-drag-x(root.icon0-x, dx, root.width);
            root.icon0-y = SumerDragDropMath.bound-drag-y(root.icon0-y, dy, root.height);
            
            root.current_grid_x = SumerDragDropMath.snap-to-grid-x(root.icon0-x, root.width);
            root.current_grid_y = SumerDragDropMath.snap-to-grid-y(root.icon0-y, root.height);
            
            // Icon 1 Evasion
            if (root.icon1-x == root.current_grid_x && root.icon1-y == root.current_grid_y) {
                root.start_drag1_x = root.icon1-x;
                root.start_drag1_y = root.icon1-y;
                root.icon1-x = SumerDragDropMath.calculate-evasion(root.icon1-x, root.icon1-y, root.icon2-x, root.icon2-y, root.last_dx, root.last_dy, root.w_max, root.h_max).x;
                root.icon1-y = SumerDragDropMath.calculate-evasion(root.start_drag1_x, root.start_drag1_y, root.icon2-x, root.icon2-y, root.last_dx, root.last_dy, root.w_max, root.h_max).y;
            }
            
            // Icon 2 Evasion
            if (root.icon2-x == root.current_grid_x && root.icon2-y == root.current_grid_y) {
                root.start_drag2_x = root.icon2-x;
                root.start_drag2_y = root.icon2-y;
                root.icon2-x = SumerDragDropMath.calculate-evasion(root.icon2-x, root.icon2-y, root.icon1-x, root.icon1-y, root.last_dx, root.last_dy, root.w_max, root.h_max).x;
                root.icon2-y = SumerDragDropMath.calculate-evasion(root.start_drag2_x, root.start_drag2_y, root.icon1-x, root.icon1-y, root.last_dx, root.last_dy, root.w_max, root.h_max).y;
            }
        }
    }
    
    if (root.show-console) : SumerDesktopIcon {
        x: root.icon1-x;
        y: root.icon1-y;
        text: root.app-models[1].name;
        icon: "💻";
        is-focused: root.focused-index == 1;
        dark-mode: root.dark-mode;
        is-dragged: root.active-drag-index == 1;
        hide-for-proxy: root.active-drag-index == 1;
        bg-color: root.app-models[1].bg_color;
        hover-bg-color: root.app-models[1].hover_bg_color;
        
        clicked => {
            root.focused-index = 1;
            root.open-console();
        }
        drag-started => { 
            root.active-drag-index = 1; 
            root.start_drag1_x = root.icon1-x;
            root.start_drag1_y = root.icon1-y;
        }
        drag-ended => {
            root.active-drag-index = -1;
            if (root.icon1-y > root.height - 250px) {
                root.icon1-x = 24px;
                root.icon1-y = 200px;
                root.dropped-in-dock("console");
            } else {
                root.target_x = SumerDragDropMath.snap-to-grid-x(root.icon1-x + (root.last_dx * 1.5), root.width);
                root.target_y = SumerDragDropMath.snap-to-grid-y(root.icon1-y + (root.last_dy * 1.5), root.height);
                
                if (root.icon0-x == root.target_x && root.icon0-y == root.target_y) {
                    root.icon0-x = root.start_drag1_x;
                    root.icon0-y = root.start_drag1_y;
                }
                if (root.icon2-x == root.target_x && root.icon2-y == root.target_y) {
                    root.icon2-x = root.start_drag1_x;
                    root.icon2-y = root.start_drag1_y;
                }
                
                root.icon1-x = root.target_x;
                root.icon1-y = root.target_y;
            }
            root.last_dx = 0px;
            root.last_dy = 0px;
        }
        dragged-by(dx, dy) => {
            root.last_dx = dx;
            root.last_dy = dy;
            root.icon1-x = SumerDragDropMath.bound-drag-x(root.icon1-x, dx, root.width);
            root.icon1-y = SumerDragDropMath.bound-drag-y(root.icon1-y, dy, root.height);
            
            root.current_grid_x = SumerDragDropMath.snap-to-grid-x(root.icon1-x, root.width);
            root.current_grid_y = SumerDragDropMath.snap-to-grid-y(root.icon1-y, root.height);
            
            // Icon 0 Evasion
            if (root.icon0-x == root.current_grid_x && root.icon0-y == root.current_grid_y) {
                root.start_drag0_x = root.icon0-x;
                root.start_drag0_y = root.icon0-y;
                root.icon0-x = SumerDragDropMath.calculate-evasion(root.icon0-x, root.icon0-y, root.icon2-x, root.icon2-y, root.last_dx, root.last_dy, root.w_max, root.h_max).x;
                root.icon0-y = SumerDragDropMath.calculate-evasion(root.start_drag0_x, root.start_drag0_y, root.icon2-x, root.icon2-y, root.last_dx, root.last_dy, root.w_max, root.h_max).y;
            }
            
            // Icon 2 Evasion
            if (root.icon2-x == root.current_grid_x && root.icon2-y == root.current_grid_y) {
                root.start_drag2_x = root.icon2-x;
                root.start_drag2_y = root.icon2-y;
                root.icon2-x = SumerDragDropMath.calculate-evasion(root.icon2-x, root.icon2-y, root.icon0-x, root.icon0-y, root.last_dx, root.last_dy, root.w_max, root.h_max).x;
                root.icon2-y = SumerDragDropMath.calculate-evasion(root.start_drag2_x, root.start_drag2_y, root.icon0-x, root.icon0-y, root.last_dx, root.last_dy, root.w_max, root.h_max).y;
            }
        }
    }
    
    if (root.show-tv) : SumerDesktopIcon {
        x: root.icon2-x;
        y: root.icon2-y;
        text: root.app-models[2].name;
        icon: "📺";
        is-focused: root.focused-index == 2;
        dark-mode: root.dark-mode;
        is-dragged: root.active-drag-index == 2;
        hide-for-proxy: root.active-drag-index == 2;
        bg-color: root.app-models[2].bg_color;
        hover-bg-color: root.app-models[2].hover_bg_color;
        
        clicked => {
            root.focused-index = 2;
            root.launch-tv();
        }
        drag-started => { 
            root.active-drag-index = 2; 
            root.start_drag2_x = root.icon2-x;
            root.start_drag2_y = root.icon2-y;
        }
        drag-ended => {
            root.active-drag-index = -1;
            if (root.icon2-y > root.height - 250px) {
                root.icon2-x = 24px;
                root.icon2-y = 320px;
                root.dropped-in-dock("tv");
            } else {
                root.target_x = SumerDragDropMath.snap-to-grid-x(root.icon2-x + (root.last_dx * 1.5), root.width);
                root.target_y = SumerDragDropMath.snap-to-grid-y(root.icon2-y + (root.last_dy * 1.5), root.height);
                
                if (root.icon0-x == root.target_x && root.icon0-y == root.target_y) {
                    root.icon0-x = root.start_drag2_x;
                    root.icon0-y = root.start_drag2_y;
                }
                if (root.icon1-x == root.target_x && root.icon1-y == root.target_y) {
                    root.icon1-x = root.start_drag2_x;
                    root.icon1-y = root.start_drag2_y;
                }
                
                root.icon2-x = root.target_x;
                root.icon2-y = root.target_y;
            }
            root.last_dx = 0px;
            root.last_dy = 0px;
        }
        dragged-by(dx, dy) => {
            root.last_dx = dx;
            root.last_dy = dy;
            root.icon2-x = SumerDragDropMath.bound-drag-x(root.icon2-x, dx, root.width);
            root.icon2-y = SumerDragDropMath.bound-drag-y(root.icon2-y, dy, root.height);
            
            root.current_grid_x = SumerDragDropMath.snap-to-grid-x(root.icon2-x, root.width);
            root.current_grid_y = SumerDragDropMath.snap-to-grid-y(root.icon2-y, root.height);
            
            // Icon 0 Evasion
            if (root.icon0-x == root.current_grid_x && root.icon0-y == root.current_grid_y) {
                root.start_drag0_x = root.icon0-x;
                root.start_drag0_y = root.icon0-y;
                root.icon0-x = SumerDragDropMath.calculate-evasion(root.icon0-x, root.icon0-y, root.icon2-x, root.icon2-y, root.last_dx, root.last_dy, root.w_max, root.h_max).x;
                root.icon0-y = SumerDragDropMath.calculate-evasion(root.start_drag0_x, root.start_drag0_y, root.icon2-x, root.icon2-y, root.last_dx, root.last_dy, root.w_max, root.h_max).y;
            }
            
            // Icon 1 Evasion
            if (root.icon1-x == root.current_grid_x && root.icon1-y == root.current_grid_y) {
                root.start_drag1_x = root.icon1-x;
                root.start_drag1_y = root.icon1-y;
                root.icon1-x = SumerDragDropMath.calculate-evasion(root.icon1-x, root.icon1-y, root.icon2-x, root.icon2-y, root.last_dx, root.last_dy, root.w_max, root.h_max).x;
                root.icon1-y = SumerDragDropMath.calculate-evasion(root.start_drag1_x, root.start_drag1_y, root.icon2-x, root.icon2-y, root.last_dx, root.last_dy, root.w_max, root.h_max).y;
            }
        }
    }
    
    if (root.show-shortcuts) : SumerDesktopIcon {
        x: root.icon3-x;
        y: root.icon3-y;
        text: "الاختصارات";
        icon: "⌨️";
        is-focused: root.focused-index == 3;
        dark-mode: root.dark-mode;
        is-dragged: root.active-drag-index == 3;
        hide-for-proxy: root.active-drag-index == 3;
        bg-color: #64748b;
        hover-bg-color: #475569;
        
        clicked => {
            root.focused-index = 3;
            root.open-shortcuts();
        }
        drag-started => { 
            root.active-drag-index = 3; 
            root.start_drag3_x = root.icon3-x;
            root.start_drag3_y = root.icon3-y;
        }
        drag-ended => {
            root.active-drag-index = -1;
            if (root.icon3-y > root.height - 250px) {
                root.icon3-x = 24px;
                root.icon3-y = 440px;
                root.dropped-in-dock("shortcuts");
            } else {
                root.target_x = SumerDragDropMath.snap-to-grid-x(root.icon3-x + (root.last_dx * 1.5), root.width);
                root.target_y = SumerDragDropMath.snap-to-grid-y(root.icon3-y + (root.last_dy * 1.5), root.height);
                
                root.icon3-x = root.target_x;
                root.icon3-y = root.target_y;
            }
            root.last_dx = 0px;
            root.last_dy = 0px;
        }
        dragged-by(dx, dy) => {
            root.last_dx = dx;
            root.last_dy = dy;
            root.icon3-x = SumerDragDropMath.bound-drag-x(root.icon3-x, dx, root.width);
            root.icon3-y = SumerDragDropMath.bound-drag-y(root.icon3-y, dy, root.height);
        }
    }
}
