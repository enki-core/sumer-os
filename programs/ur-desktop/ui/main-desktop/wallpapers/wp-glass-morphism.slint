export component Wallpaper19 inherits Rectangle {
    in property <bool> is-preview: false;
    background: @linear-gradient(45deg, #3b82f6 0%, #8b5cf6 100%);
    Rectangle { width: is-preview ? 40px : 300px; height: is-preview ? 40px : 300px; x: parent.width/2 - (is-preview ? 30px : 200px); y: parent.height/2 - (is-preview ? 20px : 150px); border-radius: is-preview ? 20px : 150px; background: #f472b6; opacity: 0.6; }
    Rectangle { width: is-preview ? 60px : 500px; height: is-preview ? 30px : 200px; x: (parent.width - self.width)/2; y: (parent.height - self.height)/2; border-radius: is-preview ? 4px : 24px; background: #ffffff20; border-width: 1px; border-color: #ffffff40; }
}