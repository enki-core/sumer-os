import { Button, LineEdit, ScrollView } from "std-widgets.slint";

// Structs for data mapping
export struct Printer {
    id: string,
    name: string,
    port: string,
    driver: string,
    status: string,          // "جاهز", "مشغول", "غير متصل", "حبر منخفض"
    status_color: color,     // #10b981 (ready), #f59e0b (busy/low ink), #ef4444 (offline)
    is_default: bool,
    ink_c: float,            // 0.0 to 1.0
    ink_m: float,            // 0.0 to 1.0
    ink_y: float,            // 0.0 to 1.0
    ink_k: float,            // 0.0 to 1.0
    jobs_count: int,
}

export struct PrintJob {
    id: int,
    printer_name: string,
    doc_name: string,
    owner: string,
    pages: int,
    size_formatted: string,
    status: string,          // "قيد الانتظار", "يتم الطبع الآن", "مكتمل", "ملغى"
    status_color: color,
    progress: float,         // 0.0 to 1.0
    submitted_time: string,
    is_pdf: bool,
}

// Custom Glassmorphic Button
export component GlassButton inherits Rectangle {
    in-out property <string> text: "زر";
    in-out property <color> text-color: #ffffff;
    in-out property <color> bg-color: #3b82f620;
    in-out property <color> hover-bg-color: #3b82f640;
    in-out property <color> active-bg-color: #3b82f660;
    in-out property <color> border-color-default: #3b82f644;
    in-out property <length> font-size: 13px;
    in-out property <bool> is-danger: false;
    
    callback clicked();

    border-radius: 8px;
    border-width: 1px;
    border-color: root.is-danger ? #ef444466 : root.border-color-default;
    background: ta.pressed ? (root.is-danger ? #ef444460 : root.active-bg-color) : 
                ta.has-hover ? (root.is-danger ? #ef444430 : root.hover-bg-color) : 
                (root.is-danger ? #ef444415 : root.bg-color);

    height: 36px;
    
    animate background { duration: 150ms; }

    HorizontalLayout {
        alignment: center;
        padding-left: 12px;
        padding-right: 12px;
        
        Text {
            text: root.text;
            color: root.is-danger ? #fca5a5 : root.text-color;
            font-size: root.font-size;
            font-weight: 700;
            vertical-alignment: center;
        }
    }

    ta := TouchArea {
        clicked => { root.clicked(); }
    }
}

// Custom Tab Button
export component TabButton inherits Rectangle {
    in-out property <string> text: "تبويب";
    in-out property <string> icon: "📁";
    in-out property <bool> active: false;
    
    callback clicked();

    border-radius: 10px;
    background: root.active ? #3b82f625 : (ta.has-hover ? #ffffff05 : transparent);
    border-width: 1px;
    border-color: root.active ? #3b82f655 : (ta.has-hover ? #ffffff0a : transparent);
    height: 42px;

    animate background { duration: 150ms; }

    HorizontalLayout {
        spacing: 12px;
        padding-left: 16px;
        padding-right: 16px;
        alignment: end;

        Text {
            text: root.text;
            color: root.active ? #ffffff : #94a3b8;
            font-size: 13px;
            font-weight: root.active ? 700 : 500;
            vertical-alignment: center;
        }

        Text {
            text: root.icon;
            font-size: 16px;
            vertical-alignment: center;
        }
    }

    ta := TouchArea {
        clicked => { root.clicked(); }
    }
}

// Ink Cartridge Visualizer Component
export component InkTank inherits VerticalLayout {
    in-out property <string> label: "حبر";
    in-out property <float> value: 0.8; // 0.0 to 1.0
    in-out property <color> fill-color: #3b82f6;

    spacing: 6px;
    alignment: center;

    Text {
        text: Math.round(root.value * 100) + "%";
        color: #ffffff;
        font-size: 11px;
        font-weight: 700;
        horizontal-alignment: center;
    }

    // The fluid cylinder
    Rectangle {
        width: 32px;
        height: 80px;
        background: #ffffff08;
        border-radius: 6px;
        border-width: 1px;
        border-color: #ffffff1a;
        clip: true;

        // Ink fluid
        Rectangle {
            y: parent.height - self.height;
            width: parent.width;
            height: parent.height * root.value;
            background: root.fill-color;
            border-radius: 4px;
            
            animate height { duration: 300ms; easing: ease-out; }
        }
        
        // Low level alarm border
        if root.value < 0.2 : Rectangle {
            width: 100%;
            height: 100%;
            border-width: 1px;
            border-color: #ef4444aa;
            border-radius: 6px;
        }
    }

    Text {
        text: root.label;
        color: #94a3b8;
        font-size: 11px;
        font-weight: 700;
        horizontal-alignment: center;
    }
}

