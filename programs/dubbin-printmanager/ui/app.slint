                        }
                        TabButton {
                            text: "سجل العمليات";
                            icon: "📝";
                            active: root.active-tab == "logs";
                            clicked => { root.active-tab = "logs"; }
                        }
                    }

                    // 📊 Mini System Status Panel (at the bottom of sidebar)
                    Rectangle {
                        background: #ffffff03;
                        border-radius: 10px;
                        border-width: 1px;
                        border-color: #ffffff06;
                        padding: 12px;

                        VerticalLayout {
                            spacing: 8px;

                            Text {
                                text: "حالة نظام الطباعة";
