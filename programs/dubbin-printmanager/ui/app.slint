                                    padding-right: 8px;

                                    for p in root.printers : Rectangle {
                                        height: 80px;
                                        background: (root.selected-printer.id == p.id) ? #3b82f61a : (card-ta.has-hover ? #ffffff05 : #ffffff02);
                                        border-radius: 10px;
                                        border-width: 1px;
                                        border-color: (root.selected-printer.id == p.id) ? #3b82f688 : (card-ta.has-hover ? #ffffff15 : #ffffff08);
                                        padding: 12px;

                                        animate background { duration: 150ms; }
                                        
                                        HorizontalLayout {
                                            alignment: space-between;
                                            spacing: 12px;

                                            // Left portion of card: Small Ink Indicator previews & Default Star
                                            HorizontalLayout {
                                                alignment: start;
                                                spacing: 16px;
                                                
                                                // Default star badge
                                                if p.is-default : VerticalLayout {
                                                    alignment: center;
                                                    Text {
                                                        text: "⭐ الافتراضية";
                                                        color: #eab308;
                                                        font-size: 11px;
                                                        font-weight: 700;
                                                    }
                                                }

                                                // Mini Ink Levels Summary Row
                                                HorizontalLayout {
                                                    spacing: 4px;
                                                    alignment: center;
                                                    
                                                    // Black bar
                                                    Rectangle { width: 6px; height: 32px; background: #ffffff10; border-radius: 1px;
                                                        Rectangle { y: parent.height - self.height; width: 100%; height: parent.height * p.ink-k; background: #111827; border-radius: 1px; }
                                                    }
                                                    // Cyan bar
                                                    Rectangle { width: 6px; height: 32px; background: #ffffff10; border-radius: 1px;
                                                        Rectangle { y: parent.height - self.height; width: 100%; height: parent.height * p.ink-c; background: #06b6d4; border-radius: 1px; }
                                                    }
                                                    // Magenta bar
                                                    Rectangle { width: 6px; height: 32px; background: #ffffff10; border-radius: 1px;
                                                        Rectangle { y: parent.height - self.height; width: 100%; height: parent.height * p.ink-m; background: #ec4899; border-radius: 1px; }
                                                    }
                                                    // Yellow bar
                                                    Rectangle { width: 6px; height: 32px; background: #ffffff10; border-radius: 1px;
                                                        Rectangle { y: parent.height - self.height; width: 100%; height: parent.height * p.ink-y; background: #eab308; border-radius: 1px; }
                                                    }
                                                }
                                            }

                                            // Right portion of card: Icon, Name and Status
                                            HorizontalLayout {
                                                alignment: end;
                                                spacing: 12px;

                                                VerticalLayout {
                                                    alignment: center;
                                                    spacing: 4px;
                                                    
                                                    Text {
                                                        text: p.name;
                                                        font-size: 13px;
                                                        font-weight: 700;
                                                        color: #ffffff;
                                                        horizontal-alignment: right;
                                                    }
                                                    HorizontalLayout {
                                                        alignment: end;
                                                        spacing: 6px;
                                                        
                                                        Text {
                                                            text: p.port;
                                                            font-size: 11px;
                                                            color: #64748b;
                                                        }
                                                        VerticalLayout {
                                                            alignment: center;
                                                            Rectangle {
                                                                width: 6px;
                                                                height: 6px;
                                                                border-radius: 3px;
                                                                background: p.status-color;
                                                            }
                                                        }
                                                        Text {
                                                            text: p.status;
                                                            font-size: 11px;
                                                            color: p.status-color;
                                                            font-weight: 700;
                                                        }
                                                    }
                                                }

                                                // Icon
                                                Rectangle {
                                                    width: 48px;
                                                    height: 48px;
                                                    background: #ffffff04;
                                                    border-radius: 8px;
                                                    
                                                    Text {
                                                        text: "🖨️";
                                                        font-size: 22px;
                                                        horizontal-alignment: center;
                                                        vertical-alignment: center;
                                                    }
                                                }
                                            }
                                        }

                                        card-ta := TouchArea {
                                            clicked => {
                                                root.selected-printer = p;
                                                root.has-selected-printer = true;
                                                root.select-printer(p.id);
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // ------------------------------------------
                    // TAB 2: PRINT JOBS QUEUE VIEW
                    // ------------------------------------------
                    if root.active-tab == "jobs" : VerticalLayout {
                        padding: 20px;
                        spacing: 16px;

                        HorizontalLayout {
                            alignment: space-between;
                            
                            // Queue operations
                            GlassButton {
                                text: "إلغاء كافة المهام النشطة 🛑";
                                is-danger: true;
                                font-size: 12px;
                                clicked => {
                                    root.active-jobs = [];
                                    root.notification-msg = "تم مسح كافة مهام الطباعة بنجاح";
                                    root.notification-color = #10b981;
                                }
                            }

                            Text {
                                text: "قائمة وثائق الطبع قيد الانتظار والمعالجة (" + root.active-jobs.length + ")";
                                font-size: 15px;
                                font-weight: 700;
                                color: #ffffff;
                                vertical-alignment: center;
                            }
                        }

                        if root.active-jobs.length == 0 : VerticalLayout {
                            alignment: center;
                            spacing: 12px;
                            vertical-stretch: 1;

                            Text {
                                text: "📭";
                                font-size: 48px;
                                horizontal-alignment: center;
                            }
                            Text {
                                text: "لا توجد مهام طباعة قيد الانتظار حالياً";
                                font-size: 13px;
                                color: #64748b;
                                horizontal-alignment: center;
                            }
                        }

                        if root.active-jobs.length > 0 : ScrollView {
                            vertical-stretch: 1;

                            VerticalLayout {
                                spacing: 10px;
                                padding-right: 8px;

                                for job in root.active-jobs : Rectangle {
                                    background: #ffffff02;
                                    border-radius: 10px;
                                    border-width: 1px;
                                    border-color: #ffffff08;
                                    padding: 12px;

                                    VerticalLayout {
                                        spacing: 8px;

                                        // Top Row: Info & Badges
                                        HorizontalLayout {
                                            alignment: space-between;

                                            // Operations & Details
                                            HorizontalLayout {
                                                spacing: 12px;
                                                alignment: start;
                                                
                                                Text {
                                                    text: job.submitted-time;
                                                    font-size: 11px;
                                                    color: #64748b;
                                                    vertical-alignment: center;
                                                }

                                                Rectangle {
                                                    background: #ffffff08;
                                                    border-radius: 4px;
                                                    border-width: 1px;
                                                    border-color: job.status-color;
                                                    padding-left: 8px;
                                                    padding-right: 8px;
                                                    height: 20px;

                                                    Text {
                                                        text: job.status;
                                                        color: job.status-color;
                                                        font-size: 10px;
                                                        font-weight: 700;
                                                        vertical-alignment: center;
                                                    }
                                                }

                                                GlassButton {
                                                    text: "إلغاء المهمة ❌";
                                                    is-danger: true;
                                                    font-size: 10px;
                                                    height: 24px;
                                                    clicked => { root.cancel-job(job.id); }
                                                }
                                            }

                                            // Document Metadata (Arabic RTL alignment)
                                            HorizontalLayout {
                                                spacing: 12px;
                                                alignment: end;

                                                VerticalLayout {
                                                    alignment: center;
                                                    
                                                    Text {
                                                        text: job.doc_name;
                                                        font-size: 13px;
                                                        font-weight: 700;
                                                        color: #ffffff;
                                                        horizontal-alignment: right;
                                                    }
                                                    HorizontalLayout {
                                                        alignment: end;
                                                        spacing: 8px;
                                                        
                                                        Text { text: "الحجم: " + job.size_formatted; font-size: 11px; color: #cbd5e1; }
                                                        Text { text: " | "; font-size: 11px; color: #ffffff10; }
                                                        Text { text: "الصفحات: " + job.pages; font-size: 11px; color: #cbd5e1; }
                                                        Text { text: " | "; font-size: 11px; color: #ffffff10; }
                                                        Text { text: "المرسل: " + job.owner; font-size: 11px; color: #64748b; }
                                                        Text { text: " | "; font-size: 11px; color: #ffffff10; }
                                                        Text { text: "الطابعة: " + job.printer_name; font-size: 11px; color: #60a5fa; }
                                                    }
                                                }

                                                Rectangle {
                                                    width: 38px;
                                                    height: 38px;
                                                    background: #ffffff04;
                                                    border-radius: 6px;
                                                    
                                                    Text {
                                                        text: job.is_pdf ? "📕" : "📄";
                                                        font-size: 20px;
                                                        horizontal-alignment: center;
                                                        vertical-alignment: center;
                                                    }
                                                }
                                            }
                                        }

                                        // Progress Bar Row (if job is active)
                                        if job.progress > 0.0 : HorizontalLayout {
                                            spacing: 12px;
                                            
                                            Text {
                                                text: Math.round(job.progress * 100) + "%";
                                                color: #3b82f6;
                                                font-size: 11px;
                                                font-weight: 700;
                                                width: 32px;
                                                vertical-alignment: center;
                                            }

                                            // Progress bar container
                                            VerticalLayout {
                                                horizontal-stretch: 1;
                                                alignment: center;
                                                Rectangle {
                                                    height: 6px;
                                                    background: #ffffff0a;
                                                    border-radius: 3px;

                                                    // Filled progress
                                                    Rectangle {
                                                        x: 0px;
                                                        width: parent.width * job.progress;
                                                        height: parent.height;
                                                        background: @linear-gradient(90deg, #3b82f6 0%, #60a5fa 100%);
                                                        border-radius: 3px;

                                                        animate width { duration: 250ms; }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // ------------------------------------------
                    // TAB 3: ADD NEW PRINTER FORM
                    // ------------------------------------------
                    if root.active-tab == "add_printer" : VerticalLayout {
                        padding: 30px;
                        spacing: 20px;
                        alignment: center;

                        HorizontalLayout {
                            alignment: center;

                            Rectangle {
                                background: #ffffff02;
                                border-radius: 14px;
                                border-width: 1px;
                                border-color: #ffffff0a;
                                padding: 24px;
                                width: 500px;

                                VerticalLayout {
                                spacing: 18px;

                                Text {
                                    text: "إضافة طابعة جديدة للنظام";
                                    font-size: 16px;
                                    font-weight: 700;
                                    color: #ffffff;
                                    horizontal-alignment: center;
                                }

                                Rectangle { height: 1px; background: #ffffff0a; }

                                // Printer Name Input
                                VerticalLayout {
                                    spacing: 6px;
                                    Text {
                                        text: "اسم جهاز الطباعة:";
                                        font-size: 12px;
                                        color: #94a3b8;
                                        horizontal-alignment: right;
                                    }
                                    name_input := LineEdit {
                                        text: root.input-printer-name;
                                        placeholder-text: "مثال: Sumer Jet basra 400";
                                        height: 38px;
                                        edited => { root.input-printer-name = self.text; }
                                    }
                                }

                                // Connection Port / IP Input
                                VerticalLayout {
                                    spacing: 6px;
                                    Text {
                                        text: "منفذ الاتصال أو عنوان IP للشبكة:";
                                        font-size: 12px;
                                        color: #94a3b8;
                                        horizontal-alignment: right;
                                    }
                                    port_input := LineEdit {
                                        text: root.input-printer-port;
                                        placeholder-text: "مثال: USB002 أو 192.168.1.100:9100";
                                        height: 38px;
                                        edited => { root.input-printer-port = self.text; }
                                    }
                                }

                                // Connection Driver / Type Input
                                VerticalLayout {
                                    spacing: 6px;
                                    Text {
                                        text: "نوع التعريف المرفق (Driver):";
                                        font-size: 12px;
                                        color: #94a3b8;
                                        horizontal-alignment: right;
                                    }
                                    driver_input := LineEdit {
                                        text: root.input-printer-driver;
                                        placeholder-text: "مثال: Sumer Universal Laser PCL6";
                                        height: 38px;
                                        edited => { root.input-printer-driver = self.text; }
                                    }
                                }

                                Rectangle { height: 8px; }

                                // Submit Button
                                GlassButton {
                                    text: "تأكيد وإضافة الطابعة ➕";
                                    bg-color: #10b9811c;
                                    border-color: #10b98144;
                                    text-color: #6ee7b7;
                                    height: 42px;
                                    clicked => {
                                        if (root.input-printer-name == "") {
                                            root.notification-msg = "خطأ: يرجى كتابة اسم الطابعة أولاً!";
                                            root.notification-color = #ef4444;
                                            return;
                                        }
                                        root.add-new-printer(
                                            root.input-printer-name,
                                            root.input-printer-port,
                                            root.input-printer-driver
                                        );
                                        root.input-printer-name = "";
                                        root.active-tab = "printers";
                                    }
                                }
                            }
                        }
                    }
                    }

                    // ------------------------------------------
                    // TAB 4: SYSTEM ACTIVITY LOGS VIEW
                    // ------------------------------------------
                    if root.active-tab == "logs" : VerticalLayout {
                        padding: 20px;
                        spacing: 16px;

                        HorizontalLayout {
                            alignment: space-between;

                            GlassButton {
                                text: "مسح السجلات 🧹";
                                font-size: 12px;
                                clicked => {
                                    root.system-logs = ["[System] تم مسح سجلات الطباعة بواسطة المستخدم."];
                                }
                            }

                            Text {
                                text: "سجل عمليات طابعات نظام سومر OS";
                                font-size: 15px;
                                font-weight: 700;
                                color: #ffffff;
                                vertical-alignment: center;
                            }
                        }

                        ScrollView {
                            vertical-stretch: 1;

                            Rectangle {
                                background: #00000030;
                                border-radius: 10px;
                                border-width: 1px;
                                border-color: #ffffff06;
                                padding: 12px;

                                VerticalLayout {
                                    spacing: 8px;
                                    alignment: start;

                                    for log in root.system-logs : Text {
                                        text: log;
                                        font-size: 12px;
                                        color: #cbd5e1;
                                        font-family: "monospace";
                                        horizontal-alignment: right;
                                        wrap: word-wrap;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
