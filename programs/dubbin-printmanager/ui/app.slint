                        alignment: center;
                        
                        Text {
                            text: "🖨️";
                            font-size: 38px;
                            horizontal-alignment: center;
                        }
                        Text {
                            text: "دوبين لمدير الطابعات";
                            font-size: 16px;
                            font-weight: 700;
                            color: #ffffff;
                            horizontal-alignment: center;
                        }
                        Text {
                            text: "DUBBIN PRINT MANAGER";
                            font-size: 9px;
                            font-weight: 700;
                            color: #64748b;
                            horizontal-alignment: center;
                            letter-spacing: 1px;
                        }
                    }

                    // Separation Line
                    Rectangle {
                        height: 1px;
                        background: #ffffff0c;
                    }

                    // 🗂️ Navigation Tabs
                    VerticalLayout {
                        spacing: 8px;
                        vertical-stretch: 1;

                        TabButton {
                            text: "الأجهزة المتاحة";
                            icon: "🖨️";
                            active: root.active-tab == "printers";
                            clicked => { root.active-tab = "printers"; }
                        }
                        TabButton {
                            text: "انتظار الطبع (" + root.active-jobs.length + ")";
                            icon: "⏳";
