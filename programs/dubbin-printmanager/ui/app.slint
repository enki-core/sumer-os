                    background: #ffffff02;
                    border-radius: 12px;
                    border-width: 1px;
                    border-color: #ffffff09;
                    padding-left: 16px;
                    padding-right: 16px;

                    HorizontalLayout {
                        alignment: space-between;
                        
                        // Default printer quick-indicator
                        HorizontalLayout {
                            alignment: start;
                            spacing: 8px;
                            
