            status_color: #3b82f6,
            progress: 0.45,
            submitted_time: "16:20"
        },
        {
            id: 102,
            printer_name: "Basra Laser Pro 80X",
            doc_name: "مذكرة_عمليات_السيرفر.txt",
            owner: "system",
            pages: 2,
            size_formatted: "128 KB",
            status: "قيد الانتظار",
            status_color: #f59e0b,
            progress: 0.0,
            submitted_time: "16:31"
        }
    ];

    in-out property <[string]> system-logs: [
        "[16:01] تم ربط الطابعة Sumer Jet Office 5000 بنجاح عبر منفذ USB001.",
        "[16:15] تم الكشف عن طابعة الشبكة Basra Laser Pro 80X وتعيين تعريف PCL6.",
        "[16:20] بدأ المستخدم 'debian' مهمة الطباعة رقم 101 لحجم 4.2 ميجابايت.",
        "[16:31] أضاف النظام مهمة الطباعة 'مذكرة_عمليات_السيرفر' في صف الانتظار."
    ];

    in-out property <string> active-tab: "printers"; // "printers", "jobs", "add_printer", "logs"
    in-out property <Printer> selected-printer;
    in-out property <bool> has-selected-printer: false;
    
    // Add Printer form states
    in-out property <string> input-printer-name: "";
    in-out property <string> input-printer-port: "192.168.1.200:9100";
    in-out property <string> input-printer-driver: "Sumer Universal InkJet";
    
    // Notification Banner state
    in-out property <string> notification-msg: "جاهز";
    in-out property <color> notification-color: #10b981;
    in-out property <string> default-printer-name: "Sumer Jet Office 5000";

    // --- Callbacks for Rust Backend ---
    callback select-printer(string); // id
    callback set-default-printer(string); // id
    callback print-test-page(string); // id
    callback pause-printer(string); // id
    callback clear-printer-queue(string); // id
    callback delete-printer(string); // id
    callback cancel-job(int); // job_id
    callback add-new-printer(string, string, string); // name, port, driver
    callback refresh-all();

    // Init selected printer on startup if empty
    init => {
        if (root.printers.length > 0 && !root.has-selected-printer) {
            root.selected-printer = root.printers[0];
            root.has-selected-printer = true;
        }
    }

    // Root Container with Gorgeous Cyber-Glow Effect
    Rectangle {
        width: 100%;
        height: 100%;

        // 🕸️ Background Glow Spheres
        Rectangle {
            x: -120px; y: -120px; width: 350px; height: 350px;
            background: #3b82f612;
            border-radius: 175px;
        }
        Rectangle {
            x: parent.width - 200px; y: parent.height - 200px; width: 450px; height: 450px;
            background: #8b5cf60c;
            border-radius: 225px;
        }

        // Main Layout Grid
        HorizontalLayout {
            padding: 16px;
            spacing: 16px;

            // ==========================================
            // LEFT PANEL: Main Navigation and System Stats
            // ==========================================
            Rectangle {
                width: 240px;
                background: #ffffff02;
                border-radius: 14px;
                border-width: 1px;
                border-color: #ffffff09;
                padding: 16px;

                VerticalLayout {
                    spacing: 20px;

